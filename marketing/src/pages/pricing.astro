---
import Layout from '../layouts/Layout.astro';
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://app.myground.work';
---
<Layout title="Pricing · Groundwork" description="Start free. Run your first ground at no cost. $80 per ground, up to 6 people and 6 sessions. Report generates after session 1 and updates as more people check in." canonicalPath="/pricing">
  <style>
    *,*::before,*::after{box-sizing:border-box}
    body{margin:0;overflow-x:hidden}
    .gw-nav-link{font-size:13px;font-weight:500;color:#6B6560;background:none;border:none;cursor:pointer;padding:6px 11px;border-radius:6px;font-family:inherit;transition:all .15s;white-space:nowrap;text-decoration:none;display:inline-block;}
    .gw-nav-link:hover{background:#E8E6E3;color:#1A1916;}
    .gw-btn-ghost{font-size:13px;font-weight:600;color:#0C447C;background:none;border:1px solid #B5D4F4;cursor:pointer;padding:7px 14px;border-radius:6px;font-family:inherit;white-space:nowrap;transition:background .15s;text-decoration:none;display:inline-block;}
    .gw-btn-ghost:hover{background:#EEF4FB;}
    .gw-btn-solid{font-size:13px;font-weight:700;color:#fff;background:#0C447C;border:none;cursor:pointer;padding:7px 14px;border-radius:6px;font-family:inherit;white-space:nowrap;transition:background .15s;text-decoration:none;display:inline-block;}
    .gw-btn-solid:hover{background:#1557A0;}
    .gw-price-grid{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:14px;}
    .gw-price-card{flex:1;min-width:200px;background:#fff;border:1px solid #E2E0DB;border-radius:10px;padding:20px;}
    .gw-footer-btn{font-size:12px;color:rgba(255,255,255,.38);background:none;border:none;cursor:pointer;font-family:inherit;text-decoration:none;}
    .gw-footer-btn:hover{color:rgba(255,255,255,.65);}
    @media(max-width:620px){
      .gw-nav-links{display:none !important;}
      .gw-price-grid{flex-direction:column;}
      .gw-price-card{min-width:unset;width:100%;}
    }
  </style>

  <div style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#EDECEA;min-height:100vh;color:#1A1916;">

    <nav style="position:sticky;top:0;z-index:100;background:rgba(237,236,234,.96);backdrop-filter:blur(8px);border-bottom:1px solid #E2E0DB;display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;">
      <a href="/" style="display:flex;align-items:center;gap:9px;text-decoration:none;">
        <svg width="20" height="16" viewBox="0 0 22 17" fill="none">
          <rect x="5"  y="0"  width="12" height="3" rx="1.5" fill="#0C447C" opacity="0.45"/>
          <rect x="2"  y="6"  width="18" height="3" rx="1.5" fill="#0C447C" opacity="0.72"/>
          <rect x="0"  y="12" width="22" height="3" rx="1.5" fill="#0C447C"/>
        </svg>
        <span style="font-size:15px;font-weight:700;color:#0C447C;letter-spacing:-.02em;">Groundwork</span>
      </a>
      <div class="gw-nav-links" style="display:flex;align-items:center;gap:2px;">
        <a class="gw-nav-link" href="/">Home</a>
        <a class="gw-nav-link" href="/how-it-works">How it works</a>
        <a class="gw-nav-link" href="/pricing" style="background:#E8E6E3;color:#1A1916;">Pricing</a>
        <a class="gw-nav-link" href="/about">About</a>
      </div>
      <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
        <a class="gw-btn-ghost" href={`${APP_URL}/login`}>Sign in</a>
        <a class="gw-btn-solid" href={`${APP_URL}/register`}>Get started free</a>
      </div>
    </nav>

    <main style="max-width:600px;margin:0 auto;padding:56px 24px 80px;">
      <p style="font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:#0C447C;font-weight:700;margin-bottom:12px;">Pricing</p>
      <h1 style="font-size:32px;font-weight:800;color:#1A1916;line-height:1.2;margin-bottom:16px;">One ground. One price.</h1>
      <p style="font-size:16px;color:#6B6560;line-height:1.7;margin-bottom:32px;">You pay per ground, not per seat. The first ground is free so you can see how it works before spending anything.</p>

      <div class="gw-price-grid">
        <div class="gw-price-card" style="background:#F5F3EF;">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#9B9590;margin-bottom:12px;">Free</div>
          <div style="font-size:34px;font-weight:800;color:#1A1916;">$0</div>
          <div style="font-size:13px;color:#6B6560;margin:6px 0 16px;">Your first ground, no card required.</div>
          <div style="font-size:12.5px;color:#6B6560;line-height:1.7;">One ground. One check-in session. You get a report. See exactly what Groundwork does before you pay anything.</div>
        </div>
        <div class="gw-price-card" style="background:#0C447C;">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:rgba(147,197,253,.7);margin-bottom:12px;">Per ground</div>
          <div style="font-size:34px;font-weight:800;color:#fff;">$80</div>
          <div style="font-size:13px;color:rgba(255,255,255,.6);margin:6px 0 16px;">Up to 6 people, 6 sessions, 90 days.</div>
          <div style="font-size:12.5px;color:rgba(255,255,255,.75);line-height:1.7;">Report generates after session 1 and updates as more people check in. $10 per additional session or participant beyond the base.</div>
        </div>
      </div>

      <div style="background:#0A1628;color:#fff;border-radius:10px;padding:20px 22px;margin-bottom:14px;">
        <div style="font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:#5DCAA5;font-weight:700;margin-bottom:8px;">Example</div>
        <div style="font-size:14px;line-height:1.7;color:rgba(255,255,255,.92);">A founder and four team members run a ground ahead of a board meeting. That is <b style="color:#fff;">$80</b> flat. Everyone checks in once. The report is ready the same day. No monthly bill. No per-seat math.</div>
      </div>

      <div style="background:#E7F6EF;border:1px solid #BFE6D4;border-radius:10px;padding:16px 18px;margin-bottom:40px;">
        <div style="font-size:13px;color:#085041;line-height:1.7;"><b>Admin counts as one of the 6 participants if they check in.</b> The record is permanent and everyone keeps it, whether or not the ground is renewed.</div>
      </div>

      <div style="text-align:center;">
        <a class="gw-btn-solid" href={`${APP_URL}/register`} style="padding:13px 28px;font-size:14px;">Start a Ground</a>
      </div>
    </main>

    <footer style="background:#0A1628;padding:32px 24px;text-align:center;">
      <div style="display:flex;align-items:center;justify-content:center;gap:9px;margin-bottom:16px;">
        <svg width="18" height="14" viewBox="0 0 22 17" fill="none">
          <rect x="5"  y="0"  width="12" height="3" rx="1.5" fill="white" opacity="0.45"/>
          <rect x="2"  y="6"  width="18" height="3" rx="1.5" fill="white" opacity="0.72"/>
          <rect x="0"  y="12" width="22" height="3" rx="1.5" fill="white"/>
        </svg>
        <span style="font-size:14px;font-weight:700;color:rgba(255,255,255,.85);">Groundwork</span>
      </div>
      <div style="display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;margin-bottom:20px;">
        <a class="gw-footer-btn" href="/">Home</a>
        <a class="gw-footer-btn" href="/how-it-works">How it works</a>
        <a class="gw-footer-btn" href="/use-cases">Use cases</a>
        <a class="gw-footer-btn" href="/pricing">Pricing</a>
        <a class="gw-footer-btn" href="/about">About</a>
      </div>
      <p style="font-size:11px;color:rgba(255,255,255,.2);margin:0;">&#169; 2025 Groundwork.</p>
    </footer>

  </div>
</Layout>
