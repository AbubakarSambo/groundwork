---
import Layout from '../layouts/Layout.astro';
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://app.myground.work';
---
<Layout title="Pricing · Groundwork" description="Start free with 10 Grounds, no card required. Subscribe as your team grows. Unlimited Grounds, sessions, and reports on every plan." canonicalPath="/pricing">
  <style>
    *,*::before,*::after{box-sizing:border-box}
    body{margin:0;overflow-x:hidden}
    .gw-nav-link{font-size:13px;font-weight:500;color:#6B6560;background:none;border:none;cursor:pointer;padding:6px 11px;border-radius:6px;font-family:inherit;transition:all .15s;white-space:nowrap;text-decoration:none;display:inline-block;}
    .gw-nav-link:hover{background:#E8E6E3;color:#1A1916;}
    .gw-btn-ghost{font-size:13px;font-weight:600;color:#0C447C;background:none;border:1px solid #B5D4F4;cursor:pointer;padding:7px 14px;border-radius:6px;font-family:inherit;white-space:nowrap;transition:background .15s;text-decoration:none;display:inline-block;}
    .gw-btn-ghost:hover{background:#EEF4FB;}
    .gw-btn-solid{font-size:13px;font-weight:700;color:#fff;background:#0C447C;border:none;cursor:pointer;padding:7px 14px;border-radius:6px;font-family:inherit;white-space:nowrap;transition:background .15s;text-decoration:none;display:inline-block;}
    .gw-btn-solid:hover{background:#1557A0;}
    .gw-footer-btn{font-size:12px;color:rgba(255,255,255,.38);background:none;border:none;cursor:pointer;font-family:inherit;text-decoration:none;}
    .gw-footer-btn:hover{color:rgba(255,255,255,.65);}
    .plan-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px;margin-bottom:14px;}
    .plan-card{background:#fff;border:1px solid #E2E0DB;border-radius:12px;padding:22px 18px;display:flex;flex-direction:column;}
    .why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px;}
    .why-card{background:#fff;border:1px solid #E2E0DB;border-radius:10px;padding:18px 18px;}
    .faq-item{border-bottom:1px solid #E2E0DB;padding:18px 0;}
    .faq-item:last-child{border-bottom:none;}
    @media(max-width:620px){
      .gw-nav-links{display:none !important;}
      .plan-grid{grid-template-columns:1fr;}
      .why-grid{grid-template-columns:1fr;}
    }
  </style>

  <div style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#EDECEA;min-height:100vh;color:#1A1916;">

    <nav style="position:sticky;top:0;z-index:100;background:rgba(237,236,234,.96);backdrop-filter:blur(8px);border-bottom:1px solid #E2E0DB;display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;">
      <a href="/" style="display:flex;align-items:center;gap:9px;text-decoration:none;">
        <svg width="20" height="16" viewBox="0 0 22 17" fill="none">
          <rect x="5"  y="0"  width="12" height="3" rx="1.5" fill="#0C447C" opacity="0.45"/>
          <rect x="2"  y="6"  width="18" height="3" rx="1.5" fill="#0C447C" opacity="0.72"/>
          <rect x="0"  y="12" width="22" height="3" rx="1.5" fill="#0C447C"/>
        </svg>
        <span style="font-size:15px;font-weight:700;color:#0C447C;letter-spacing:-.02em;">Groundwork</span>
      </a>
      <div class="gw-nav-links" style="display:flex;align-items:center;gap:2px;">
        <a class="gw-nav-link" href="/">Home</a>
        <a class="gw-nav-link" href="/how-it-works">How it works</a>
        <a class="gw-nav-link" href="/pricing" style="background:#E8E6E3;color:#1A1916;">Pricing</a>
        <a class="gw-nav-link" href="/about">About</a>
      </div>
      <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
        <a class="gw-btn-ghost" href={`${APP_URL}/auth`}>Sign in</a>
        <a class="gw-btn-solid" href={`${APP_URL}/entry`}>Get started free</a>
      </div>
    </nav>

    <main style="max-width:760px;margin:0 auto;padding:56px 24px 80px;">

      <!-- Header -->
      <p style="font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:#0C447C;font-weight:700;margin-bottom:12px;">Pricing</p>
      <h1 style="font-size:34px;font-weight:800;color:#1A1916;line-height:1.2;margin-bottom:16px;">Simple, honest pricing.</h1>
      <p style="font-size:16px;color:#6B6560;line-height:1.7;margin-bottom:44px;max-width:520px;">Start free with 10 Grounds, no card required. Subscribe as your team grows. Unlimited Grounds, sessions, and reports on every plan.</p>

      <!-- Free tier -->
      <div style="background:#F5F3EF;border:1px solid #E2E0DB;border-radius:12px;padding:24px 26px;margin-bottom:40px;display:flex;align-items:flex-start;justify-content:space-between;gap:20px;flex-wrap:wrap;">
        <div style="flex:1;min-width:220px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
            <span style="font-size:15px;font-weight:700;color:#1A1916;">Free</span>
            <span style="font-size:11px;background:#E7F6EF;color:#085041;border:1px solid #BFE6D4;border-radius:6px;padding:2px 8px;font-weight:700;">Always</span>
          </div>
          <p style="font-size:13.5px;color:#6B6560;line-height:1.65;margin:0 0 12px;">Create up to 10 Grounds for free. No card required. Unlimited sessions and reports on every Ground.</p>
          <ul style="font-size:12.5px;color:#6B6560;padding-left:18px;margin:0;line-height:1.9;">
            <li>10 Grounds</li>
            <li>Unlimited sessions</li>
            <li>Unlimited reports</li>
            <li>Admin dashboard</li>
            <li>Templates</li>
          </ul>
        </div>
        <div style="text-align:right;flex-shrink:0;">
          <div style="font-size:30px;font-weight:800;color:#1A1916;">$0</div>
          <div style="font-size:12px;color:#9B9590;">forever</div>
          <a href={`${APP_URL}/entry`} style="display:inline-block;margin-top:12px;font-size:12px;font-weight:600;color:#0C447C;border:1px solid #B5D4F4;border-radius:7px;padding:6px 14px;text-decoration:none;">Get started free</a>
        </div>
      </div>

      <!-- Org subscriptions -->
      <h2 style="font-size:20px;font-weight:800;color:#1A1916;margin-bottom:8px;">Subscribe as your team grows</h2>
      <p style="font-size:14px;color:#6B6560;line-height:1.65;margin-bottom:24px;">Every person with a Groundwork account in your organization counts toward your plan. One flat monthly rate, unlimited everything.</p>

      <div class="plan-grid">
        <div class="plan-card">
          <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:4px;">Starter</div>
          <div style="font-size:26px;font-weight:800;color:#0C447C;margin-bottom:2px;">$25<span style="font-size:13px;font-weight:500;color:#9B9590;">/mo</span></div>
          <div style="font-size:12px;color:#9B9590;margin-bottom:12px;">Up to 5 people</div>
          <p style="font-size:12px;color:#6B6560;line-height:1.6;flex-grow:1;margin-bottom:16px;">For small teams getting started with structured check-ins.</p>
          <a href={`${APP_URL}/billing`} style="display:block;text-align:center;font-size:13px;font-weight:700;color:#fff;background:#0C447C;border-radius:8px;padding:9px;text-decoration:none;">Subscribe</a>
        </div>
        <div class="plan-card">
          <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:4px;">Small Team</div>
          <div style="font-size:26px;font-weight:800;color:#0C447C;margin-bottom:2px;">$50<span style="font-size:13px;font-weight:500;color:#9B9590;">/mo</span></div>
          <div style="font-size:12px;color:#9B9590;margin-bottom:12px;">Up to 20 people</div>
          <p style="font-size:12px;color:#6B6560;line-height:1.6;flex-grow:1;margin-bottom:16px;">For growing teams running multiple Grounds at once.</p>
          <a href={`${APP_URL}/billing`} style="display:block;text-align:center;font-size:13px;font-weight:700;color:#fff;background:#0C447C;border-radius:8px;padding:9px;text-decoration:none;">Subscribe</a>
        </div>
        <div class="plan-card">
          <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:4px;">Growth</div>
          <div style="font-size:26px;font-weight:800;color:#0C447C;margin-bottom:2px;">$100<span style="font-size:13px;font-weight:500;color:#9B9590;">/mo</span></div>
          <div style="font-size:12px;color:#9B9590;margin-bottom:12px;">Up to 100 people</div>
          <p style="font-size:12px;color:#6B6560;line-height:1.6;flex-grow:1;margin-bottom:16px;">For organizations running Groundwork across departments or client groups.</p>
          <a href={`${APP_URL}/billing`} style="display:block;text-align:center;font-size:13px;font-weight:700;color:#fff;background:#0C447C;border-radius:8px;padding:9px;text-decoration:none;">Subscribe</a>
        </div>
        <div class="plan-card">
          <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:4px;">Business</div>
          <div style="font-size:26px;font-weight:800;color:#0C447C;margin-bottom:2px;">$200<span style="font-size:13px;font-weight:500;color:#9B9590;">/mo</span></div>
          <div style="font-size:12px;color:#9B9590;margin-bottom:12px;">Up to 250 people</div>
          <p style="font-size:12px;color:#6B6560;line-height:1.6;flex-grow:1;margin-bottom:16px;">For larger organizations with multiple teams and Grounds in flight.</p>
          <a href={`${APP_URL}/billing`} style="display:block;text-align:center;font-size:13px;font-weight:700;color:#fff;background:#0C447C;border-radius:8px;padding:9px;text-decoration:none;">Subscribe</a>
        </div>
        <div class="plan-card">
          <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:4px;">Scale</div>
          <div style="font-size:26px;font-weight:800;color:#0C447C;margin-bottom:2px;">$400<span style="font-size:13px;font-weight:500;color:#9B9590;">/mo</span></div>
          <div style="font-size:12px;color:#9B9590;margin-bottom:12px;">Up to 1,000 people</div>
          <p style="font-size:12px;color:#6B6560;line-height:1.6;flex-grow:1;margin-bottom:16px;">For organizations scaling Groundwork across a large workforce.</p>
          <a href={`${APP_URL}/billing`} style="display:block;text-align:center;font-size:13px;font-weight:700;color:#fff;background:#0C447C;border-radius:8px;padding:9px;text-decoration:none;">Subscribe</a>
        </div>
      </div>

      <!-- Enterprise -->
      <div style="background:#0A1628;border-radius:12px;padding:22px 26px;margin-bottom:48px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;">
        <div>
          <div style="font-size:15px;font-weight:700;color:#fff;margin-bottom:6px;">Enterprise</div>
          <p style="font-size:13px;color:rgba(255,255,255,.6);line-height:1.6;margin:0;">For organizations with custom needs, volume pricing, or dedicated support.</p>
        </div>
        <a href="mailto:hello@groundwork.so" style="font-size:13px;font-weight:700;color:#fff;border:1px solid rgba(255,255,255,.3);border-radius:8px;padding:9px 20px;text-decoration:none;white-space:nowrap;">Contact us</a>
      </div>

      <!-- Why we price this way -->
      <h2 style="font-size:20px;font-weight:800;color:#1A1916;margin-bottom:8px;">Why we price this way</h2>
      <p style="font-size:14px;color:#6B6560;line-height:1.65;margin-bottom:24px;">Most tools charge you for seats and call it a feature. We charge you for your team size and give you everything.</p>

      <div class="why-grid" style="margin-bottom:48px;">
        <div class="why-card">
          <div style="font-size:13px;font-weight:700;color:#1A1916;margin-bottom:6px;">Start free, no card required.</div>
          <p style="font-size:12.5px;color:#6B6560;line-height:1.65;margin:0;">10 Grounds is enough to know whether Groundwork works for your team. No credit card, no trial that expires, no pressure to upgrade before you have seen the value.</p>
        </div>
        <div class="why-card">
          <div style="font-size:13px;font-weight:700;color:#1A1916;margin-bottom:6px;">Pay for your team size, not your usage.</div>
          <p style="font-size:12.5px;color:#6B6560;line-height:1.65;margin:0;">Every person with a Groundwork account in your organization counts toward your plan. Unlimited Grounds, sessions, and reports at every tier. No counting clicks.</p>
        </div>
        <div class="why-card">
          <div style="font-size:13px;font-weight:700;color:#1A1916;margin-bottom:6px;">One price, no tiers per feature.</div>
          <p style="font-size:12.5px;color:#6B6560;line-height:1.65;margin:0;">Every plan gives you the same thing: full AI-facilitated check-ins, structured reports, and a permanent record. No features locked behind higher tiers.</p>
        </div>
        <div class="why-card">
          <div style="font-size:13px;font-weight:700;color:#1A1916;margin-bottom:6px;">Transparent and consistent.</div>
          <p style="font-size:12.5px;color:#6B6560;line-height:1.65;margin:0;">The price you see is the price you pay. No proration surprises, no hidden add-ons, no sudden price changes without notice.</p>
        </div>
      </div>

      <!-- FAQ -->
      <h2 style="font-size:20px;font-weight:800;color:#1A1916;margin-bottom:8px;">Common questions</h2>
      <p style="font-size:14px;color:#6B6560;margin-bottom:24px;">Answers to what most people ask before they start.</p>

      <div style="margin-bottom:48px;">
        <div class="faq-item">
          <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:6px;">What counts as a "person" on my plan?</div>
          <p style="font-size:13px;color:#6B6560;line-height:1.65;margin:0;">Every person with a Groundwork account in your organization counts, whether they create Grounds or just participate in them. Guests with no account do not count.</p>
        </div>
        <div class="faq-item">
          <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:6px;">Do I need a card to start?</div>
          <p style="font-size:13px;color:#6B6560;line-height:1.65;margin:0;">No. Your first 10 Grounds are free and require no payment details. You add a card only when you want to create more than 10.</p>
        </div>
        <div class="faq-item">
          <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:6px;">What counts as a session?</div>
          <p style="font-size:13px;color:#6B6560;line-height:1.65;margin:0;">One session is one full round of check-ins across all participants on a Ground. Whether you have two people or twenty, it is one session. Sessions are unlimited on every plan.</p>
        </div>
        <div class="faq-item">
          <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:6px;">Can I cancel a subscription at any time?</div>
          <p style="font-size:13px;color:#6B6560;line-height:1.65;margin:0;">Yes. Cancel from the billing page and your subscription ends at the close of the billing period. No penalties, no questions.</p>
        </div>
        <div class="faq-item">
          <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:6px;">What happens to my Grounds and reports if I cancel?</div>
          <p style="font-size:13px;color:#6B6560;line-height:1.65;margin:0;">Nothing is deleted. Your reports and history stay on your account. You can read everything that happened. You can still run Grounds on the free plan (up to 10 total).</p>
        </div>
        <div class="faq-item">
          <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:6px;">Does every participant need to pay?</div>
          <p style="font-size:13px;color:#6B6560;line-height:1.65;margin:0;">No. Billing is at the organization level, based on your team size. Participants who have a Groundwork account count toward your plan. External participants without an account do not.</p>
        </div>
      </div>

      <!-- Guiding principle -->
      <div style="text-align:center;padding:36px 28px;background:#fff;border:1px solid #E2E0DB;border-radius:14px;">
        <p style="font-size:16px;color:#6B6560;max-width:440px;margin:0 auto 20px;line-height:1.75;font-style:italic;">"Pay when something real happens. Stop when it doesn't. We built the pricing to match how trust actually works."</p>
        <a class="gw-btn-solid" href={`${APP_URL}/entry`} style="padding:11px 24px;font-size:14px;">Start your first Ground free</a>
      </div>

    </main>

    <footer style="background:#0A1628;padding:32px 24px;text-align:center;">
      <div style="display:flex;align-items:center;justify-content:center;gap:9px;margin-bottom:16px;">
        <svg width="18" height="14" viewBox="0 0 22 17" fill="none">
          <rect x="5"  y="0"  width="12" height="3" rx="1.5" fill="white" opacity="0.45"/>
          <rect x="2"  y="6"  width="18" height="3" rx="1.5" fill="white" opacity="0.72"/>
          <rect x="0"  y="12" width="22" height="3" rx="1.5" fill="white"/>
        </svg>
        <span style="font-size:14px;font-weight:700;color:rgba(255,255,255,.85);">Groundwork</span>
      </div>
      <div style="display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;margin-bottom:20px;">
        <a class="gw-footer-btn" href="/">Home</a>
        <a class="gw-footer-btn" href="/how-it-works">How it works</a>
        <a class="gw-footer-btn" href="/use-cases">Use cases</a>
        <a class="gw-footer-btn" href="/pricing">Pricing</a>
        <a class="gw-footer-btn" href="/about">About</a>
      </div>
      <p style="font-size:11px;color:rgba(255,255,255,.2);margin:0;">&#169; 2025 Groundwork.</p>
    </footer>

  </div>
</Layout>
