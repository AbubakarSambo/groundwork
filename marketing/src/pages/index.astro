---
import Layout from '../layouts/Layout.astro';
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://app.myground.work';

const FEATURES = [
  { icon: '💬', title: 'Everyone gets their own private chat', desc: 'Check in on goals, get honest feedback, build a record of what you actually built.' },
  { icon: '📊', title: 'Everyone aligns on the same picture', desc: 'Not a mood update. The real thing. Who is moving, who needs support, what is actually happening.' },
  { icon: '📄', title: 'Download your contribution record anytime.', desc: 'Your record, your goals, your period. Yours to keep and share.' },
]

const MOMENTS = [
  {
    icon: '+',
    title: 'When something new is starting.',
    desc: 'Build alignment in from the beginning. Have the renewal or review conversation with a record rather than a feeling.',
    rows: [
      { label: 'New senior hire', sub: 'define success in the first 90 days before interpretation drift begins' },
      { label: 'New cofounder or partner', sub: 'agree contribution upfront so the equity conversation has something to stand on' },
      { label: 'New board member or advisor', sub: 'set expectations and track whether the relationship returns what it costs' },
      { label: 'New project', sub: 'set scope, ownership, and success criteria before work starts' },
    ],
  },
  {
    icon: '↑',
    title: 'When someone wants recognition.',
    desc: 'A raise, equity, or promotion conversation grounded in a record built over time. Both sides see the same picture.',
    rows: [
      { label: 'Asking for a raise', sub: 'the record makes the case — specific, evidenced, built over time' },
      { label: 'Equity negotiation', sub: 'contribution over time is documented before the conversation happens' },
      { label: 'Promotion or role change', sub: 'the case is built from the record, not assembled in the moment' },
    ],
  },
  {
    icon: '👁',
    title: 'When you need everyone seeing the same thing.',
    desc: 'Pressure, conflict, or misalignment that needs a reset. Shared facts so the team can move forward together.',
    rows: [
      { label: 'Cofounder or partner tension', sub: 'contribution imbalance that the relationship makes impossible to name' },
      { label: 'A relationship that has quietly drifted', sub: 'the cost is compounding and the conversation keeps being deferred' },
      { label: 'Team misalignment', sub: 'people working hard in different directions without realising it' },
    ],
  },
]
---
<Layout title="Groundwork — See clearly when it counts">
  <style>
    *,*::before,*::after{box-sizing:border-box}
    body{margin:0;overflow-x:hidden}
    .gw-nav{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid #E2E0DB;background:#EDECEA;gap:12px}
    .gw-nav-left{display:flex;align-items:center;gap:8px;min-width:0}
    .gw-nav-logo{font-size:15px;font-weight:700;color:#0C447C;letter-spacing:-0.02em;white-space:nowrap}
    .gw-nav-tag{font-size:11px;color:#9B9590;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap}
    .gw-nav-sign{font-size:13px;font-weight:600;color:#0C447C;border:1px solid #B5D4F4;padding:6px 14px;border-radius:6px;text-decoration:none;white-space:nowrap;flex-shrink:0}
    .gw-body{padding:48px 20px 48px;max-width:520px;margin:0 auto;width:100%}
    .gw-h1{font-size:38px;font-weight:700;line-height:1.08;letter-spacing:-0.03em;color:#1A1916;margin:0 0 20px}
    .gw-cta-row{display:flex;flex-direction:column;gap:10px;margin-bottom:48px}
    .gw-cta-primary{display:flex;align-items:center;justify-content:space-between;width:100%;padding:15px 18px;border-radius:6px;background:#0C447C;color:white;font-size:15px;font-weight:700;text-decoration:none}
    .gw-cta-secondary{display:flex;align-items:center;justify-content:space-between;width:100%;padding:15px 18px;border-radius:6px;background:white;color:#1A1916;font-size:15px;font-weight:600;border:1px solid #E2E0DB;text-decoration:none}
    .gw-feature{display:flex;align-items:flex-start;gap:14px;min-width:0}
    .gw-feature-icon{width:32px;height:32px;border-radius:6px;background:#EEF4FB;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px}
    .gw-feature-text{min-width:0}
    .gw-divider{height:1px;background:#E2E0DB;margin-bottom:28px}
    @media(max-width:480px){
      .gw-nav-tag{display:none}
      .gw-h1{font-size:30px}
      .gw-body{padding:36px 16px 48px}
    }
  </style>

  <div style="background:#EDECEA;color:#1A1916;min-height:100vh;font-family:system-ui,sans-serif;">

    <!-- Nav -->
    <nav class="gw-nav">
      <div class="gw-nav-left">
        <span class="gw-nav-logo">Groundwork</span>
        <span class="gw-nav-tag">See clearly when it counts.</span>
      </div>
      <a href={`${APP_URL}/login`} class="gw-nav-sign">Sign in</a>
    </nav>

    <!-- Body -->
    <div class="gw-body">

      <!-- Hero -->
      <div style="font-size:11px;font-weight:600;color:#0C447C;text-transform:uppercase;letter-spacing:.1em;margin-bottom:16px;opacity:.65;">
        Contribution intelligence
      </div>
      <h1 class="gw-h1">
        See clearly<br><span style="color:#0C447C;">when it counts.</span>
      </h1>
      <p style="font-size:15px;color:#6B6560;line-height:1.7;margin:0 0 36px;">
        Everyone builds an honest record of their work. Founders, managers and team members finally see the same picture.
      </p>

      <!-- CTAs -->
      <div class="gw-cta-row">
        <a href={`${APP_URL}/register`} class="gw-cta-primary">
          <span>Set up your org</span>
          <span style="font-size:13px;font-weight:400;opacity:.7;">Get started →</span>
        </a>
        <a href={`${APP_URL}/login`} class="gw-cta-secondary">
          <span>Open my chat</span>
          <span style="font-size:13px;font-weight:400;color:#9B9590;">Team members →</span>
        </a>
      </div>

      <div class="gw-divider"></div>

      <!-- Features -->
      <div style="font-size:11px;color:#9B9590;text-transform:uppercase;letter-spacing:.1em;margin-bottom:20px;">Three things. One picture.</div>
      <div style="display:flex;flex-direction:column;gap:16px;margin-bottom:40px;">
        {FEATURES.map(f => (
          <div class="gw-feature">
            <div class="gw-feature-icon">{f.icon}</div>
            <div class="gw-feature-text">
              <div style="font-size:14px;font-weight:600;color:#1A1916;margin-bottom:3px;">{f.title}</div>
              <div style="font-size:13px;color:#6B6560;line-height:1.6;">{f.desc}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="gw-divider"></div>

      <!-- Three moments -->
      <div style="font-size:11px;color:#9B9590;text-transform:uppercase;letter-spacing:.1em;margin-bottom:20px;">Groundwork brings alignment to three moments.</div>
      <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:32px;">
        {MOMENTS.map(m => (
          <div style="background:white;border:1px solid #E2E0DB;border-radius:8px;padding:18px 16px;">
            <div style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:8px;">{m.icon} {m.title}</div>
            <div style="font-size:12px;color:#6B6560;line-height:1.6;margin-bottom:12px;">{m.desc}</div>
            <div style="display:flex;flex-direction:column;gap:5px;">
              {m.rows.map(r => (
                <div style="font-size:12px;color:#6B6560;padding:7px 10px;border-radius:6px;border:1px solid #E2E0DB;line-height:1.5;">
                  <strong style="color:#1A1916;font-weight:600;">{r.label}</strong> {r.sub}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Privacy note -->
      <div style="background:white;border:1px solid #E2E0DB;border-radius:6px;padding:14px 16px;margin-bottom:48px;">
        <div style="font-size:12px;font-weight:700;color:#6B6560;margin-bottom:6px;">Your chat is yours. Always.</div>
        <div style="font-size:12px;color:#9B9590;line-height:1.65;">Nothing leaves without you saying so. Your record is never shared without your explicit confirmation for a named decision chosen by you.</div>
      </div>

    </div>
  </div>
</Layout>
