---
import Layout from '../layouts/Layout.astro';
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://app.myground.work';
---
<Layout title="Groundwork — See clearly when it counts">
  <style>
    *,*::before,*::after{box-sizing:border-box}
    body{margin:0;overflow-x:hidden}

    @keyframes gw-blink  { 0%,100%{opacity:1} 50%{opacity:0} }
    @keyframes gw-pulse  { 0%,100%{box-shadow:0 0 0 0 rgba(93,202,165,.5)} 50%{box-shadow:0 0 0 5px rgba(93,202,165,0)} }
    @keyframes gw-fadein { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
    .gw-cursor { color:#93C5FD; animation:gw-blink 1s step-end infinite; }
    .gw-pulse  { animation:gw-pulse 2s ease-in-out infinite; border-radius:50%; }
    .gw-pulse2 { animation:gw-pulse 2.5s ease-in-out infinite; border-radius:50%; }
    .gw-feed-item { animation:gw-fadein .4s ease forwards; }
    .gw-nav-link { font-size:13px;font-weight:500;color:#6B6560;background:none;border:none;cursor:pointer;padding:6px 11px;border-radius:6px;font-family:inherit;transition:all .15s;white-space:nowrap;text-decoration:none;display:inline-block; }
    .gw-nav-link:hover { background:#E8E6E3;color:#1A1916; }
    .gw-btn-ghost { font-size:13px;font-weight:600;color:#0C447C;background:none;border:1px solid #B5D4F4;cursor:pointer;padding:7px 14px;border-radius:6px;font-family:inherit;white-space:nowrap;transition:background .15s;text-decoration:none;display:inline-block; }
    .gw-btn-ghost:hover { background:#EEF4FB; }
    .gw-btn-solid { font-size:13px;font-weight:700;color:#fff;background:#0C447C;border:none;cursor:pointer;padding:7px 14px;border-radius:6px;font-family:inherit;white-space:nowrap;transition:background .15s;text-decoration:none;display:inline-block; }
    .gw-btn-solid:hover { background:#1557A0 !important; }
    .gw-hero-btn-p { padding:13px 24px;border-radius:6px;background:#0C447C;color:#fff;font-size:14px;font-weight:700;border:none;cursor:pointer;font-family:inherit;transition:background .15s;text-decoration:none;display:inline-block; }
    .gw-hero-btn-p:hover { background:#1557A0; }
    .gw-hero-btn-g { padding:13px 24px;border-radius:6px;background:rgba(255,255,255,.07);color:rgba(255,255,255,.8);font-size:14px;font-weight:600;border:1px solid rgba(255,255,255,.12);cursor:pointer;font-family:inherit;transition:background .15s;text-decoration:none;display:inline-block; }
    .gw-hero-btn-g:hover { background:rgba(255,255,255,.12); }
    .gw-prob-card { background:white;border-radius:8px;border:1px solid #E2E0DB;padding:16px 14px 16px 18px;position:relative;overflow:hidden; }
    .gw-prob-card::before { content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:#0C447C; }
    .gw-trust-item { display:flex;align-items:flex-start;gap:12px;padding:13px 0;border-bottom:1px solid #E8E6E3; }
    .gw-trust-item:last-child { border-bottom:none; }
    .gw-demo-btn { display:flex;align-items:flex-start;gap:11px;padding:13px;border-radius:8px;background:white;border:1px solid #E2E0DB;cursor:pointer;font-family:inherit;text-align:left;transition:all .15s;width:100%;text-decoration:none; }
    .gw-demo-btn:hover { border-color:#B5D4F4;background:#EEF4FB;transform:translateY(-1px); }
    .gw-footer-btn { font-size:12px;color:rgba(255,255,255,.38);background:none;border:none;cursor:pointer;font-family:inherit;text-decoration:none; }
    .gw-footer-btn:hover { color:rgba(255,255,255,.65); }
    @media(max-width:900px){
      .gw-hero-inner  { grid-template-columns:1fr !important; }
      .gw-prob-grid   { grid-template-columns:1fr 1fr !important; }
      .gw-mom-grid    { grid-template-columns:1fr !important; }
      .gw-trust-grid  { grid-template-columns:1fr !important; gap:32px !important; }
      .gw-price-grid  { grid-template-columns:1fr !important; }
      .gw-about-grid  { grid-template-columns:1fr !important; }
    }
    @media(max-width:620px){
      .gw-nav-links  { display:none !important; }
      .gw-hero-h1    { font-size:26px !important; min-height:auto !important; }
      .gw-hero-btns  { flex-direction:column; }
      .gw-hero-btns .gw-hero-btn-p,.gw-hero-btns .gw-hero-btn-g { width:100%;text-align:center;padding:16px 20px !important;font-size:15px !important; }
      .gw-prob-grid  { grid-template-columns:1fr !important; }
      .gw-demo-grid  { grid-template-columns:1fr !important; }
      .gw-sec-h2     { font-size:26px !important; }
      .gw-cta-h2     { font-size:26px !important; }
      .gw-wrap       { padding:40px 16px !important; }
    }
  </style>

  <div style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#EDECEA;min-height:100vh;color:#1A1916;">

    <!-- NAV -->
    <nav style="position:sticky;top:0;z-index:100;background:rgba(237,236,234,.96);backdrop-filter:blur(8px);border-bottom:1px solid #E2E0DB;display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;">
      <a href="#home" onclick="scrollTo('home');return false;" style="display:flex;align-items:center;gap:9px;text-decoration:none;">
        <svg width="20" height="16" viewBox="0 0 22 17" fill="none">
          <rect x="5"  y="0"  width="12" height="3" rx="1.5" fill="#0C447C" opacity="0.45"/>
          <rect x="2"  y="6"  width="18" height="3" rx="1.5" fill="#0C447C" opacity="0.72"/>
          <rect x="0"  y="12" width="22" height="3" rx="1.5" fill="#0C447C"/>
        </svg>
        <span style="font-size:15px;font-weight:700;color:#0C447C;letter-spacing:-.02em;">Groundwork</span>
      </a>
      <div class="gw-nav-links" style="display:flex;align-items:center;gap:2px;">
        <a class="gw-nav-link" href="#home"   onclick="gwScroll('home');return false;">Home</a>
        <a class="gw-nav-link" href="#how"    onclick="gwScroll('how');return false;">How it works</a>
        <a class="gw-nav-link" href="#pricing" onclick="gwScroll('pricing');return false;">Pricing</a>
        <a class="gw-nav-link" href="#about"  onclick="gwScroll('about');return false;">About</a>
      </div>
      <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
        <a class="gw-btn-ghost" href={`${APP_URL}/login`}>Sign in</a>
        <a class="gw-btn-solid" href={`${APP_URL}/register`}>Get started free</a>
      </div>
    </nav>

    <!-- HERO -->
    <section id="home" style="background:#0A1628;position:relative;overflow:hidden;">
      <svg style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;opacity:.07;" xmlns="http://www.w3.org/2000/svg">
        <defs><pattern id="lgrid" width="48" height="48" patternUnits="userSpaceOnUse">
          <path d="M 48 0 L 0 0 0 48" fill="none" stroke="#93C5FD" stroke-width="0.4"/>
        </pattern></defs>
        <rect width="100%" height="100%" fill="url(#lgrid)" opacity="0.8"/>
        <line x1="140" y1="90" x2="300" y2="60" stroke="#93C5FD" stroke-width="0.5" opacity="0.15"/>
        <line x1="300" y1="60" x2="480" y2="130" stroke="#93C5FD" stroke-width="0.5" opacity="0.13"/>
        <line x1="480" y1="130" x2="640" y2="80" stroke="#5DCAA5" stroke-width="0.5" opacity="0.12"/>
        <line x1="640" y1="80" x2="800" y2="140" stroke="#93C5FD" stroke-width="0.5" opacity="0.1"/>
      </svg>
      <div class="gw-hero-inner" style="position:relative;padding:56px 20px 52px;max-width:1080px;margin:0 auto;display:grid;grid-template-columns:1fr 380px;gap:44px;align-items:start;">
        <div>
          <div style="font-size:10px;font-weight:600;color:rgba(147,197,253,.65);text-transform:uppercase;letter-spacing:.14em;margin-bottom:20px;">Contribution intelligence</div>
          <h1 class="gw-hero-h1" id="gw-hero-h1" style="font-size:44px;font-weight:800;line-height:1.08;letter-spacing:-.04em;color:#FFFFFF;margin:0 0 22px;min-height:160px;">
            <span id="gw-tw"></span><span class="gw-cursor" id="gw-cursor">|</span>
          </h1>
          <p style="font-size:15px;color:rgba(255,255,255,.52);line-height:1.75;margin:0 0 16px;max-width:440px;">A shared record of contribution. Built from both sides. Cross referenced over time.</p>
          <div style="margin-bottom:32px;min-height:28px;display:flex;align-items:center;gap:10px;">
            <span class="gw-pulse" style="width:6px;height:6px;background:#5DCAA5;flex-shrink:0;display:inline-block;"></span>
            <span id="gw-situation" style="font-size:13px;color:rgba(255,255,255,.55);font-weight:500;transition:opacity .3s ease;"></span>
          </div>
          <div class="gw-hero-btns" style="display:flex;gap:10px;flex-wrap:wrap;">
            <a class="gw-hero-btn-p" href={`${APP_URL}/register`}>Set up your org free →</a>
            <a class="gw-hero-btn-g" href={`${APP_URL}/enter-org-code`}>Open my chat →</a>
          </div>
        </div>

        <!-- Feed panel -->
        <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:10px;overflow:hidden;">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:11px 14px;border-bottom:1px solid rgba(255,255,255,.07);background:rgba(255,255,255,.03);">
            <div style="display:flex;align-items:center;gap:7px;">
              <span class="gw-pulse" style="width:7px;height:7px;background:#5DCAA5;display:inline-block;flex-shrink:0;"></span>
              <span style="font-size:10px;font-weight:600;color:rgba(255,255,255,.55);letter-spacing:.08em;text-transform:uppercase;">Live feed</span>
            </div>
            <span id="gw-feed-count" style="font-size:10px;color:rgba(255,255,255,.2);">3 events</span>
          </div>
          <div id="gw-feed-list" style="min-height:230px;display:flex;flex-direction:column;justify-content:flex-end;"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;padding:10px 14px;border-top:1px solid rgba(255,255,255,.06);gap:4px;">
            <div><div style="font-size:17px;font-weight:700;color:#FFFFFF;text-align:center;">12</div><div style="font-size:9px;color:rgba(255,255,255,.28);text-align:center;margin-top:2px;letter-spacing:.02em;">active grounds</div></div>
            <div><div style="font-size:17px;font-weight:700;color:#FFFFFF;text-align:center;">3</div><div style="font-size:9px;color:rgba(255,255,255,.28);text-align:center;margin-top:2px;letter-spacing:.02em;">reports today</div></div>
            <div><div style="font-size:17px;font-weight:700;color:#FFFFFF;text-align:center;">47</div><div style="font-size:9px;color:rgba(255,255,255,.28);text-align:center;margin-top:2px;letter-spacing:.02em;">check-ins this week</div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROBLEM -->
    <section style="background:#F5F3EF;border-bottom:1px solid #E2E0DB;">
      <div class="gw-wrap" style="max-width:1080px;margin:0 auto;padding:64px 20px;text-align:center;">
        <p style="font-size:10px;font-weight:600;color:#0C447C;text-transform:uppercase;letter-spacing:.14em;margin-bottom:18px;opacity:.65;">The problem</p>
        <h2 class="gw-sec-h2" style="font-size:36px;font-weight:800;color:#1A1916;letter-spacing:-.03em;line-height:1.15;max-width:660px;margin:0 auto 16px;">
          The problem is not performance.<br>It is <em style="color:#0C447C;font-style:normal;">visibility.</em>
        </h2>
        <p style="font-size:15px;color:#6B6560;line-height:1.75;margin:0 auto 44px;max-width:500px;">
          Most teams do not know who is carrying critical work, where expectations diverged, who is blocked, or whether contribution matches perception. So conversations become political.
        </p>
        <div class="gw-prob-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;max-width:900px;margin:0 auto;">
          <div class="gw-prob-card"><div style="font-size:13px;font-weight:700;color:#1A1916;margin-bottom:4px;">Who is carrying</div><div style="font-size:12px;color:#6B6560;line-height:1.55;">Critical work that is invisible until someone leaves</div></div>
          <div class="gw-prob-card"><div style="font-size:13px;font-weight:700;color:#1A1916;margin-bottom:4px;">Where it diverged</div><div style="font-size:12px;color:#6B6560;line-height:1.55;">Expectations that were never the same on both sides</div></div>
          <div class="gw-prob-card"><div style="font-size:13px;font-weight:700;color:#1A1916;margin-bottom:4px;">Who is blocked</div><div style="font-size:12px;color:#6B6560;line-height:1.55;">Progress limited by things nobody named in time</div></div>
          <div class="gw-prob-card"><div style="font-size:13px;font-weight:700;color:#1A1916;margin-bottom:4px;">Whether it matches</div><div style="font-size:12px;color:#6B6560;line-height:1.55;">Contribution that does not match what people perceive</div></div>
        </div>
      </div>
    </section>

    <!-- THREE MOMENTS -->
    <section style="border-bottom:1px solid #E2E0DB;">
      <div class="gw-wrap" style="max-width:1080px;margin:0 auto;padding:64px 20px;">
        <p style="font-size:10px;font-weight:600;color:#0C447C;text-transform:uppercase;letter-spacing:.14em;margin-bottom:18px;opacity:.65;">Three moments</p>
        <h2 class="gw-sec-h2" style="font-size:36px;font-weight:800;color:#1A1916;letter-spacing:-.03em;line-height:1.15;margin-bottom:14px;">Groundwork exists for three moments.</h2>
        <p style="font-size:15px;color:#6B6560;line-height:1.75;margin-bottom:40px;max-width:500px;">Every professional relationship eventually reaches one of them. The record you built before makes each one possible.</p>
        <div class="gw-mom-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;">

          <div style="background:#FFFFFF;border-radius:10px;border:1px solid #E2E0DB;padding:26px 22px;border-top:3px solid #0C447C;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
              <span class="gw-pulse2" style="width:7px;height:7px;background:#5DCAA5;flex-shrink:0;display:inline-block;"></span>
              <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#085041;">Starting mode</span>
            </div>
            <h3 style="font-size:18px;font-weight:700;color:#1A1916;margin-bottom:8px;letter-spacing:-.02em;line-height:1.3;">When something new is starting.</h3>
            <p style="font-size:13px;color:#6B6560;line-height:1.65;margin-bottom:14px;">Build alignment in from the beginning before reality gets interpreted differently by different people.</p>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#0C447C;flex-shrink:0;margin-top:5px;"></span><span><strong>New senior hire.</strong> Define success before interpretation drift begins</span></div>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#0C447C;flex-shrink:0;margin-top:5px;"></span><span><strong>New cofounder or partner.</strong> Agree contribution upfront so equity has something to stand on</span></div>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#0C447C;flex-shrink:0;margin-top:5px;"></span><span><strong>New board member or advisor.</strong> Set expectations before the relationship costs more than it returns</span></div>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#0C447C;flex-shrink:0;margin-top:5px;"></span><span><strong>New project.</strong> Scope, ownership, and success criteria before work starts</span></div>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#0C447C;flex-shrink:0;margin-top:5px;"></span><span><strong>Contract renewal.</strong> Renewal or exit based on the record, not relationship management</span></div>
          </div>

          <div style="background:#FFFFFF;border-radius:10px;border:1px solid #E2E0DB;padding:26px 22px;border-top:3px solid #E8A94A;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
              <span class="gw-pulse2" style="width:7px;height:7px;background:#E8A94A;flex-shrink:0;display:inline-block;"></span>
              <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#8A5C1A;">Recognition</span>
            </div>
            <h3 style="font-size:18px;font-weight:700;color:#1A1916;margin-bottom:8px;letter-spacing:-.02em;line-height:1.3;">When someone wants recognition.</h3>
            <p style="font-size:13px;color:#6B6560;line-height:1.65;margin-bottom:14px;">A raise, equity, or promotion conversation grounded in a record built over time. Both sides see the same picture.</p>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#E8A94A;flex-shrink:0;margin-top:5px;"></span><span><strong>Asking for a raise.</strong> The record makes the case, built over time, not assembled the night before</span></div>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#E8A94A;flex-shrink:0;margin-top:5px;"></span><span><strong>Equity negotiation.</strong> Contribution documented before the conversation happens</span></div>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#E8A94A;flex-shrink:0;margin-top:5px;"></span><span><strong>Promotion or role change.</strong> The case is built from the record, not assembled in the moment</span></div>
          </div>

          <div style="background:#FFFFFF;border-radius:10px;border:1px solid #E2E0DB;padding:26px 22px;border-top:3px solid #5DCAA5;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
              <span class="gw-pulse2" style="width:7px;height:7px;background:#5DCAA5;flex-shrink:0;display:inline-block;"></span>
              <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#085041;">Alignment</span>
            </div>
            <h3 style="font-size:18px;font-weight:700;color:#1A1916;margin-bottom:8px;letter-spacing:-.02em;line-height:1.3;">When you need everyone seeing the same thing.</h3>
            <p style="font-size:13px;color:#6B6560;line-height:1.65;margin-bottom:14px;">Pressure, conflict, or misalignment that needs a reset. Shared facts so the team can move forward together.</p>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;margin-top:5px;"></span><span><strong>Revenue pressure or cash crunch.</strong> The whole team needs to pull in the same direction now</span></div>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;margin-top:5px;"></span><span><strong>Team misalignment.</strong> People working hard in different directions without realising it</span></div>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;margin-top:5px;"></span><span><strong>Cofounder tension.</strong> Contribution imbalance that the relationship makes impossible to name</span></div>
            <div style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#6B6560;line-height:1.5;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;margin-top:5px;"></span><span><strong>A relationship that has drifted.</strong> The cost is compounding and the conversation keeps being deferred</span></div>
          </div>

        </div>
      </div>
    </section>

    <!-- DEMO -->
    <section style="background:#F5F3EF;border-bottom:1px solid #E2E0DB;">
      <div class="gw-wrap" style="max-width:1080px;margin:0 auto;padding:64px 20px;">
        <p style="font-size:10px;font-weight:600;color:#0C447C;text-transform:uppercase;letter-spacing:.14em;margin-bottom:18px;opacity:.65;">See it working</p>
        <h2 class="gw-sec-h2" style="font-size:36px;font-weight:800;color:#1A1916;letter-spacing:-.03em;line-height:1.15;margin-bottom:14px;">Try a live demo.</h2>
        <p style="font-size:15px;color:#6B6560;line-height:1.75;margin-bottom:40px;max-width:500px;">No sign-up. Real data from Northgate Ventures.</p>
        <div class="gw-demo-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:10px;max-width:900px;">
          <a class="gw-demo-btn" href={`${APP_URL}/pin?org=northgate`}><span style="width:8px;height:8px;border-radius:50%;background:#0C447C;flex-shrink:0;margin-top:3px;"></span><div><div style="font-size:13px;font-weight:700;color:#1A1916;margin-bottom:2px;">The founder's view</div><div style="font-size:12px;color:#9B9590;line-height:1.4;">Full team picture. Who is moving, who needs support</div></div></a>
          <a class="gw-demo-btn" href={`${APP_URL}/pin?org=northgate`}><span style="width:8px;height:8px;border-radius:50%;background:#0C447C;flex-shrink:0;margin-top:3px;"></span><div><div style="font-size:13px;font-weight:700;color:#1A1916;margin-bottom:2px;">Kwame's check-in · cofounder</div><div style="font-size:12px;color:#9B9590;line-height:1.4;">Building the technical record across sessions</div></div></a>
