            <div style="font-size:34px;font-weight:800;color:#1A1916;margin-bottom:4px;">$0</div>
            <div style="font-size:13px;color:#6B6560;margin-bottom:22px;">Sessions 1 and 2 for everyone</div>
            <div style="display:flex;align-items:center;gap:7px;font-size:13px;color:#4A5568;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;"></span>Sessions 1 and 2 for all participants</div>
            <div style="display:flex;align-items:center;gap:7px;font-size:13px;color:#4A5568;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;"></span>Session 1 report included</div>
            <div style="display:flex;align-items:center;gap:7px;font-size:13px;color:#4A5568;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;"></span>Ground confidence score</div>
            <div style="display:flex;align-items:center;gap:7px;font-size:13px;color:#4A5568;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;"></span>Up to 20 participants per ground</div>
            <div style="display:flex;align-items:center;gap:7px;font-size:13px;color:#4A5568;margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;"></span>No card required</div>
          </div>
          <div style="border-radius:10px;padding:26px;background:#0C447C;">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.5);margin-bottom:14px;">Paid</div>
            <div style="font-size:34px;font-weight:800;color:white;margin-bottom:4px;">$25<span style="font-size:15px;font-weight:400;opacity:.6;">/month</span></div>
            <div style="font-size:13px;color:rgba(255,255,255,.5);margin-bottom:22px;">Platform fee + $25/active participant</div>
            <div style="display:flex;align-items:center;gap:7px;font-size:13px;color:rgba(255,255,255,.75);margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;"></span>Everything in the free tier</div>
            <div style="display:flex;align-items:center;gap:7px;font-size:13px;color:rgba(255,255,255,.75);margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;"></span>Session 3 onwards, unlimited Grounds</div>
            <div style="display:flex;align-items:center;gap:7px;font-size:13px;color:rgba(255,255,255,.75);margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;"></span>Shareable Ground Report card</div>
            <div style="display:flex;align-items:center;gap:7px;font-size:13px;color:rgba(255,255,255,.75);margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;"></span>Portable verified profile</div>
            <div style="display:flex;align-items:center;gap:7px;font-size:13px;color:rgba(255,255,255,.75);margin-bottom:5px;"><span style="width:5px;height:5px;border-radius:50%;background:#5DCAA5;flex-shrink:0;"></span>Permanent resolution record</div>
          </div>
        </div>
        <div style="background:#F5F3EF;border-radius:10px;padding:24px;border:1px solid #E2E0DB;margin-bottom:32px;">
          <h3 style="font-size:15px;font-weight:700;color:#1A1916;margin-bottom:16px;">How the session model works</h3>
          <div style="display:flex;gap:14px;align-items:flex-start;margin-bottom:10px;"><span style="font-size:11px;font-weight:700;color:#0C447C;min-width:80px;padding-top:2px;flex-shrink:0;">At setup</span><span style="font-size:13px;color:#6B6560;line-height:1.6;">Choose your timeframe and check-in cadence. The product shows your free and paid sessions before you confirm.</span></div>
          <div style="display:flex;gap:14px;align-items:flex-start;margin-bottom:10px;"><span style="font-size:11px;font-weight:700;color:#0C447C;min-width:80px;padding-top:2px;flex-shrink:0;">Sessions 1–2</span><span style="font-size:13px;color:#6B6560;line-height:1.6;">Free for all parties. Session 1 report is included. No card required.</span></div>
          <div style="display:flex;gap:14px;align-items:flex-start;margin-bottom:10px;"><span style="font-size:11px;font-weight:700;color:#0C447C;min-width:80px;padding-top:2px;flex-shrink:0;">After session 2</span><span style="font-size:13px;color:#6B6560;line-height:1.6;">Payment prompt fires to the admin. The session 2 report is released once billing is active. Session 3 onwards requires an active account.</span></div>
          <div style="display:flex;gap:14px;align-items:flex-start;margin-bottom:10px;"><span style="font-size:11px;font-weight:700;color:#0C447C;min-width:80px;padding-top:2px;flex-shrink:0;">On close</span><span style="font-size:13px;color:#6B6560;line-height:1.6;">Billing stops automatically. The resolution record is permanent. Both parties keep it forever.</span></div>
        </div>
        <div style="text-align:center;">
          <a class="gw-btn-solid" href={`${APP_URL}/`} style="padding:13px 28px;font-size:14px;font-weight:700;">Start free</a>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" style="background:#EDECEA;border-top:1px solid #E2E0DB;">
      <div class="gw-wrap" style="max-width:720px;margin:0 auto;padding:64px 20px;">
        <p style="font-size:10px;font-weight:600;color:#0C447C;text-transform:uppercase;letter-spacing:.14em;margin-bottom:18px;opacity:.65;">About</p>
        <h2 class="gw-sec-h2" style="font-size:36px;font-weight:800;color:#1A1916;letter-spacing:-.03em;line-height:1.15;margin-bottom:32px;">Built by people who kept running into the same problem.</h2>
        <div style="display:flex;flex-direction:column;gap:18px;margin-bottom:40px;">
          <p style="font-size:15px;color:#4A5568;line-height:1.8;margin:0;">Groundwork was created by friends who built and ran businesses and repeatedly ran into alignment issues within their teams.</p>
          <p style="font-size:15px;color:#4A5568;line-height:1.8;margin:0;">They saw talented contributors go unnoticed, while others who added little value often remained in place because there was no clear way to surface contributions, expectations, and gaps.</p>
          <p style="font-size:15px;color:#4A5568;line-height:1.8;margin:0;">Groundwork was designed to bring clarity to how teams work, helping founders and managers make better people decisions based on evidence rather than assumptions and biases.</p>
        </div>
        <div style="border-left:3px solid #0C447C;padding:20px;background:#EEF4FB;border-radius:0 8px 8px 0;margin-bottom:36px;">
          <h3 style="font-size:15px;font-weight:700;color:#0C447C;margin-bottom:8px;">The founding principle</h3>
          <p style="font-size:14px;color:#1A1916;line-height:1.75;font-style:italic;margin:0;">The record belongs to the people who built it. Not the organisation. Not the platform. The person. That is what makes honesty possible and what makes every other capability in the product work.</p>
        </div>
        <div class="gw-about-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:36px;">
          <div style="padding:20px;background:#F5F3EF;border-radius:8px;border:1px solid #E2E0DB;"><h3 style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:6px;">The product</h3><p style="font-size:12px;color:#6B6560;line-height:1.6;margin:0;">Contribution intelligence for professional relationships that matter. Both versions. Cross referenced over time. For two people or twenty.</p></div>
          <div style="padding:20px;background:#F5F3EF;border-radius:8px;border:1px solid #E2E0DB;"><h3 style="font-size:14px;font-weight:700;color:#1A1916;margin-bottom:6px;">The company</h3><p style="font-size:12px;color:#6B6560;line-height:1.6;margin:0;">Groundwork is an independent product built to bring clarity to professional relationships and help teams make better decisions based on evidence.</p></div>
        </div>
        <div style="height:1px;background:#E2E0DB;margin:8px 0 36px;"></div>

        <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:36px;">
          <p style="font-size:15px;color:#4A5568;line-height:1.8;margin:0;">Built for teams operating in Africa, in the moments you need a read on how contribution and alignment are going.</p>
          <p style="font-size:15px;color:#4A5568;line-height:1.8;margin:0;">Built for the critical periods, and for the teams who lead through the toughest environments.</p>
          <p style="font-size:15px;color:#4A5568;line-height:1.8;margin:0;">Groundwork is built for African leaders: the managers, founders, and companies making hard decisions about people and partnerships.</p>
        </div>

        <div class="gw-about-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:36px;">
          <div style="padding:20px;background:#F5F3EF;border-radius:8px;border:1px solid #E2E0DB;">
            <div style="font-size:10px;font-weight:600;color:#0C447C;text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px;opacity:.65;">Our headquarters</div>
            <div style="font-size:13px;font-weight:700;color:#1A1916;margin-bottom:4px;">Groundwork</div>
            <div style="font-size:12px;color:#6B6560;line-height:1.8;">9 Wendy Court, David Osieli Road<br>Westlands, Nairobi, Kenya</div>
          </div>
          <div style="padding:20px;background:#F5F3EF;border-radius:8px;border:1px solid #E2E0DB;">
            <div style="font-size:10px;font-weight:600;color:#0C447C;text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px;opacity:.65;">Incubated by</div>
            <div style="font-size:13px;font-weight:700;color:#1A1916;">CoAmana</div>
          </div>
        </div>

        <div style="text-align:center;">
          <p style="font-size:13px;color:#9B9590;margin-bottom:10px;">Questions or feedback</p>
          <a href="mailto:hello@myground.work" style="font-size:15px;font-weight:700;color:#0C447C;text-decoration:none;">hello@myground.work</a>
        </div>
      </div>
    </section>

    <!-- FEEDBACK WIDGET -->
    <div class="gw-fb-panel" id="gw-fb-panel" data-open="false">
      <div id="gw-fb-confirmed" style="display:none" class="gw-fb-confirm">Your feedback was received. Thank you.</div>
      <div id="gw-fb-form">
        <div class="gw-fb-tabs">
          <button class="gw-fb-tab active" data-tab="reaction">Reaction</button>
          <button class="gw-fb-tab" data-tab="build_request">Build request</button>
          <button class="gw-fb-tab" data-tab="something_went_wrong">Something went wrong</button>
        </div>
        <div class="gw-fb-body">
          <div class="gw-fb-heading" id="gw-fb-heading">What is your reaction?</div>
          <div class="gw-fb-pills" id="gw-fb-pills"></div>
          <div class="gw-fb-opt-label" id="gw-fb-opt-label">Add a note (optional)</div>
          <textarea class="gw-fb-input" id="gw-fb-input" rows="3"></textarea>
          <button class="gw-fb-send" id="gw-fb-send" disabled>Send</button>
          <div class="gw-fb-error" id="gw-fb-error" style="display:none"></div>
          <div class="gw-fb-note">Your response is anonymous.</div>
        </div>
      </div>
    </div>
    <div class="gw-fb-trigger">
      <button class="gw-fb-btn" id="gw-fb-btn" aria-label="Open feedback">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M2 2h14a1 1 0 011 1v9a1 1 0 01-1 1H6l-4 3V3a1 1 0 011-1z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>
      </button>
      <span class="gw-fb-label">Feedback</span>
    </div>

    <!-- FOOTER -->
    <footer style="background:#091525;padding:36px 20px;">
      <div style="max-width:1080px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
        <div style="display:flex;align-items:center;gap:9px;">
          <svg width="18" height="14" viewBox="0 0 22 17" fill="none">
            <rect x="5"  y="0"  width="12" height="3" rx="1.5" fill="#93C5FD" opacity="0.4"/>
            <rect x="2"  y="6"  width="18" height="3" rx="1.5" fill="#93C5FD" opacity="0.65"/>
            <rect x="0"  y="12" width="22" height="3" rx="1.5" fill="#93C5FD"/>
          </svg>
          <span style="font-size:13px;font-weight:700;color:white;">Groundwork</span>
        </div>
        <div style="display:flex;gap:20px;">
          <a class="gw-footer-btn" href="#how"     onclick="gwScroll('how');return false;">How it works</a>
          <a class="gw-footer-btn" href="#pricing" onclick="gwScroll('pricing');return false;">Pricing</a>
          <a class="gw-footer-btn" href="#about"   onclick="gwScroll('about');return false;">About</a>
        </div>
        <div style="font-size:11px;color:rgba(255,255,255,.22);">Powered by Coamana · 2025</div>
      </div>
    </footer>

  </div>

  <script>
    const TYPEWRITER_TEXT = "Build alignment\nbefore you build\nanything else."
    const PARAS = [
      "Clarity before commitment.",
      "Turn assumptions into agreements.",
      "Build alignment before complexity.",
      "Better decisions start with better ground.",
    ]
    const FEED_ITEMS = [
      { t:'check-in',   c:'#5DCAA5', h:'Kwame completed session 3',    s:'Cofounder ground · technical record building' },
      { t:'confidence', c:'#93C5FD', h:'Ground confidence 3/5 to 4/5', s:'Both parties active · cross-reference fired' },
      { t:'new ground', c:'#E8A94A', h:'Tarini opened a new ground',    s:'Head of Growth invited · starting mode' },
      { t:'report',     c:'#93C5FD', h:'Report generating',             s:'Both parties completed session 4' },
      { t:'signal',     c:'#5DCAA5', h:'Specificity increasing',        s:'Pattern signal · 3 consecutive sessions' },
      { t:'check-in',   c:'#5DCAA5', h:'Amara submitted her check-in',  s:'Contribution confirmed by downstream team' },
      { t:'resolved',   c:'#E8A94A', h:'Ground closed',                 s:'Alignment confirmed · both parties' },
      { t:'new ground', c:'#E8A94A', h:'New ground opened',             s:'Something new is starting · 2 parties' },
      { t:'check-in',   c:'#5DCAA5', h:'Priya completed session 2',     s:'Invisible contribution surfaced' },
      { t:'record',     c:'#93C5FD', h:'Resolution record written',     s:'Belongs to both parties permanently' },
      { t:'confidence', c:'#93C5FD', h:'Ground confidence: 5/5',        s:'Comprehensive evidence · full cross-reference' },
      { t:'check-in',   c:'#5DCAA5', h:'Ibrahim completed session 1',   s:'Cofounder ground · both accounts independent' },
    ]

    function gwScroll(id) {
      document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' })
    }
    window.gwScroll = gwScroll

    // Typewriter
    ;(function() {
      const el = document.getElementById('gw-tw')
      const cursor = document.getElementById('gw-cursor')
      if (!el) return
      const chars = TYPEWRITER_TEXT.split('')
      let i = 0, html = ''
      function tick() {
        if (i >= chars.length) {
          cursor.style.display = 'none'
          el.innerHTML = 'Build alignment<br>before you build<br><em style="color:#93C5FD;font-style:normal;">anything else.</em>'
          return
        }
        const ch = chars[i++]
        html += ch === '\n' ? '<br>' : ch.replace(/&/g,'&amp;').replace(/</g,'&lt;')
        el.innerHTML = html
        setTimeout(tick, i < 20 ? 42 : i < 42 ? 30 : 24)
      }
      setTimeout(tick, 600)
    })()

    // Paragraph cycling
    ;(function() {
      const el = document.getElementById('gw-para')
      if (!el) return
      let idx = 0
      function show() {
        el.style.opacity = '0'
        setTimeout(() => {
          el.textContent = PARAS[idx]
          el.style.opacity = '1'
          idx = (idx + 1) % PARAS.length
        }, 550)
      }
      show()
      setInterval(show, 6500)
    })()

    // Live feed
    ;(function() {
      const list = document.getElementById('gw-feed-list')
      const countEl = document.getElementById('gw-feed-count')
      if (!list) return
      let feedIdx = 3, totalEvents = 3
      const items = []

      function renderItem(id, item, age) {
        const div = document.createElement('div')
        div.className = 'gw-feed-item'
        div.style.cssText = 'padding:8px 14px;border-bottom:1px solid rgba(255,255,255,.04);'
        div.innerHTML = `
          <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
            <div style="display:flex;align-items:center;gap:6px;">
              <span style="font-size:9px;font-weight:700;padding:2px 6px;border-radius:3px;background:${item.c}22;color:${item.c};text-transform:uppercase;letter-spacing:.04em;">${item.t}</span>
              <span style="font-size:12px;font-weight:600;color:rgba(255,255,255,.85);">${item.h}</span>
            </div>
            <span style="font-size:10px;color:rgba(255,255,255,.22);flex-shrink:0;white-space:nowrap;">${age}</span>
          </div>
          <div style="font-size:11px;color:rgba(255,255,255,.32);margin-top:2px;">${item.s}</div>
        `
        return div
      }

      // seed initial 3
      for (let k = 0; k < 3; k++) {
        const age = `${(3 - k) * 4}s ago`
        items.push({ id: k + 1, item: FEED_ITEMS[k], age })
        list.appendChild(renderItem(k + 1, FEED_ITEMS[k], age))
      }

      setInterval(() => {
        const item = FEED_ITEMS[feedIdx % FEED_ITEMS.length]
        feedIdx++
        totalEvents++
        countEl.textContent = `${totalEvents} events`
        items.push({ id: totalEvents, item, age: 'just now' })
        if (items.length > 4) {
          items.shift()
          list.removeChild(list.firstChild)
        }
        list.appendChild(renderItem(totalEvents, item, 'just now'))
      }, 3800)
    })()


    // Feedback widget
    ;(function() {
      const API = (import.meta.env.PUBLIC_API_URL ?? 'https://api.myground.work') + '/api/v1'
      const TABS = {
        reaction:              { heading: 'What is your reaction?',      optLabel: 'Add a note (optional)',      required: false, pills: ['This is exactly what I needed.','This could work for me.','Interesting but not sure yet.','Not built for my situation.','Too much to take in.','I do not trust it yet.','This feels like it matters.','I would not use this.','Other.'] },
        build_request:         { heading: 'What would you like built?',  optLabel: 'Describe what you need',     required: true,  pills: ['Add a feature.','Change something that exists.','This works but needs to be simpler.','Build this for my specific situation.'] },
        something_went_wrong:  { heading: 'What went wrong?',            optLabel: 'Tell us what happened',      required: true,  pills: ['It broke and I could not continue.','It lost something I wrote.','It did not do what I expected.','Something felt wrong but I cannot name it.'] },
      }

      var panel     = document.getElementById('gw-fb-panel')
      var openBtn   = document.getElementById('gw-fb-btn')
      var form      = document.getElementById('gw-fb-form')
      var confirmed = document.getElementById('gw-fb-confirmed')
      var heading   = document.getElementById('gw-fb-heading')
      var pillsEl   = document.getElementById('gw-fb-pills')
      var optLabel  = document.getElementById('gw-fb-opt-label')
      var input     = document.getElementById('gw-fb-input')
      var sendBtn   = document.getElementById('gw-fb-send')
      var errorEl   = document.getElementById('gw-fb-error')
      var tabBtns   = document.querySelectorAll('.gw-fb-tab')

      var currentTab  = 'reaction'
      var currentPill = null
      var closeTimer  = null
      var isOpen      = false

      function renderPills(tab) {
        pillsEl.innerHTML = ''
        currentPill = null
        sendBtn.disabled = true
        TABS[tab].pills.forEach(function(p) {
          var b = document.createElement('button')
          b.className = 'gw-fb-pill'
          b.textContent = p
          b.addEventListener('click', function() {
            pillsEl.querySelectorAll('.gw-fb-pill').forEach(function(x) { x.classList.remove('selected') })
            b.classList.add('selected')
            currentPill = p
            errorEl.style.display = 'none'
            updateSendState()
          })
          pillsEl.appendChild(b)
        })
      }

      function updateSendState() {
        var needsText = TABS[currentTab].required && !input.value.trim()
        sendBtn.disabled = !currentPill || needsText
      }

      function switchTab(tab) {
        currentTab = tab
        currentPill = null
        input.value = ''
        errorEl.style.display = 'none'
        heading.textContent   = TABS[tab].heading
        optLabel.textContent  = TABS[tab].optLabel
        tabBtns.forEach(function(b) { b.classList.toggle('active', b.dataset.tab === tab) })
        renderPills(tab)
        updateSendState()
      }

      function openPanel() {
        isOpen = true
        panel.setAttribute('data-open', 'true')
        openBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>'
      }

      function closePanel() {
        isOpen = false
        panel.setAttribute('data-open', 'false')
        openBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M2 2h14a1 1 0 011 1v9a1 1 0 01-1 1H6l-4 3V3a1 1 0 011-1z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>'
        setTimeout(function() {
          confirmed.style.display = 'none'
          form.style.display = ''
          switchTab('reaction')
        }, 220)
      }

      tabBtns.forEach(function(b) {
        b.addEventListener('click', function() { switchTab(b.dataset.tab) })
      })

      input.addEventListener('input', function() {
        errorEl.style.display = 'none'
        updateSendState()
      })

      sendBtn.addEventListener('click', function() {
        if (!currentPill) return
        if (TABS[currentTab].required && !input.value.trim()) {
          errorEl.textContent = 'Please add a description before sending.'
          errorEl.style.display = ''
          return
        }
        sendBtn.disabled = true
        sendBtn.textContent = 'Sending…'
        errorEl.style.display = 'none'
        var body = { tab: currentTab, pill: currentPill }
        if (input.value.trim()) body.text = input.value.trim()
        fetch(API + '/feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        }).then(function() {
          form.style.display = 'none'
          confirmed.style.display = ''
          closeTimer = setTimeout(closePanel, 2800)
        }).catch(function() {
          sendBtn.disabled = false
          sendBtn.textContent = 'Send'
          errorEl.textContent = 'Could not send. Please try again.'
          errorEl.style.display = ''
        })
      })

      openBtn.addEventListener('click', function() {
        if (closeTimer) { clearTimeout(closeTimer); closeTimer = null }
        isOpen ? closePanel() : openPanel()
      })

      renderPills('reaction')
    })()
  </script>
</Layout>
