    </div>
    <div style="font-size:11px;color:rgba(255,255,255,.22)">© 2025 Groundwork</div>
  </div>
</footer>

</div><!-- /s-land -->

<script>
(function(){

var pages = ['home','how','usecases','pricing','about'];
window.lNav = function(p){
  pages.forEach(function(pg){
    var el = document.getElementById('lp-'+pg);
    if(el) el.style.display = pg===p?'block':'none';
  });
  document.querySelectorAll('.l-nav-link').forEach(function(b,i){
    b.classList.toggle('active', pages[i]===p);
  });
  window.scrollTo({top:0,behavior:'smooth'});
};

/* Typewriter — prototype uses id=lt / id=lc but hero has static h1; skip */

/* Feed */
var items = [
  {t:'check-in',   c:'#5DCAA5', h:'Kwame completed session 3',     s:'Cofounder ground · technical record building'},
  {t:'confidence', c:'#93C5FD', h:'Ground confidence 3/5 to 4/5',  s:'Both parties active · cross-reference fired'},
  {t:'new ground', c:'#E8A94A', h:'Tarini opened a new ground',     s:'Head of Growth invited · starting mode'},
  {t:'report',     c:'#93C5FD', h:'Report generating',              s:'Both parties completed session 4'},
  {t:'signal',     c:'#5DCAA5', h:'Specificity increasing',         s:'Pattern signal · 3 consecutive sessions'},
  {t:'check-in',   c:'#5DCAA5', h:'Amara submitted her check-in',   s:'Contribution confirmed by downstream team'},
  {t:'resolved',   c:'#E8A94A', h:'Ground closed',                  s:'Alignment confirmed · both parties'},
  {t:'new ground', c:'#E8A94A', h:'New ground opened',              s:'Something new is starting · 2 parties'},
  {t:'check-in',   c:'#5DCAA5', h:'Priya completed session 2',      s:'Invisible contribution surfaced'},
  {t:'record',     c:'#93C5FD', h:'Resolution record written',      s:'Belongs to both parties permanently'},
  {t:'confidence', c:'#93C5FD', h:'Ground confidence: 5/5',         s:'Comprehensive evidence · full cross-reference'},
  {t:'check-in',   c:'#5DCAA5', h:'Ibrahim completed session 1',    s:'Cofounder ground · both accounts independent'},
];
var feed=document.getElementById('lf'),ecount=document.getElementById('lec');
var shown=[],idx=0,total=0;
function timeAgo(ms){var s=Math.floor(ms/1000);return s<60?s+'s ago':Math.floor(s/60)+'m ago';}
function addItem(){
  var it=items[idx%items.length];idx++;total++;
  var ts=Date.now(),d=document.createElement('div');d.className='l-feed-item';
  d.innerHTML='<div style="display:flex;align-items:center;justify-content:space-between;gap:8px">'+
    '<div style="display:flex;align-items:center;gap:6px">'+
    '<span style="font-size:9px;font-weight:700;padding:2px 6px;border-radius:3px;background:'+it.c+'22;color:'+it.c+';text-transform:uppercase;letter-spacing:.04em">'+it.t+'</span>'+
    '<span style="font-size:12px;font-weight:600;color:rgba(255,255,255,.85)">'+it.h+'</span></div>'+
    '<span class="lts" data-ts="'+ts+'" style="font-size:10px;color:rgba(255,255,255,.22);flex-shrink:0;white-space:nowrap">just now</span></div>'+
    '<div style="font-size:11px;color:rgba(255,255,255,.32);margin-top:2px">'+it.s+'</div>';
  shown.push({el:d,ts:ts});
  if(shown.length>4){
    var old=shown.shift();
    old.el.style.transition='opacity .3s';old.el.style.opacity='0';
    setTimeout(function(){if(old.el.parentNode)old.el.parentNode.removeChild(old.el);},320);
  }
  if(feed) feed.appendChild(d);
  if(ecount) ecount.textContent=total+' events';
}
function updTimes(){if(feed) feed.querySelectorAll('.lts').forEach(function(e){e.textContent=timeAgo(Date.now()-parseInt(e.dataset.ts));});}
if(feed){
  for(var k=0;k<3;k++) addItem();
  setInterval(addItem,3800);setInterval(updTimes,12000);
}

/* Stats */
var v=[12,3,47];
function flash(id,val,col){var e=document.getElementById(id);if(!e)return;e.textContent=val;e.style.color=col;setTimeout(function(){e.style.color='white';},700);}
setInterval(function(){var r=Math.random();if(r<.45){v[2]++;flash('ls3',v[2],'#5DCAA5');}else if(r<.7){v[0]++;flash('ls1',v[0],'#93C5FD');}else{v[1]++;flash('ls2',v[1],'#E8A94A');}},9000);

/* Cycling situations: fading paragraphs */
var sits=[
  "Clarity before commitment.",
  "Turn assumptions into agreements.",
  "Build alignment before complexity.",
  "Better decisions start with better ground."
];
var sitEl=document.getElementById('l-sit-text');
var sitIdx=0;
function cycleSit(){
  if(!sitEl) return;
  sitEl.style.opacity='0';
  setTimeout(function(){
    sitIdx=(sitIdx+1)%sits.length;
    sitEl.textContent=sits[sitIdx];
    sitEl.style.opacity='1';
  },650);
}
if(sitEl){ sitEl.textContent=sits[0]; setTimeout(function(){ sitEl.style.opacity='1'; },60); }
setInterval(cycleSit,5600);

/* Scroll fade */
var obs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting)e.target.classList.add('in');});},{threshold:0.1});
document.querySelectorAll('.l-fade').forEach(function(el){obs.observe(el);});

})();
</script>

</body>
</html>
