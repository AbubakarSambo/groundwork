---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Groundwork — See clearly when it counts">
  <main style="max-width:720px;margin:0 auto;padding:80px 24px;font-family:system-ui,sans-serif;">
    <h1 style="font-size:2.5rem;font-weight:700;">Most people's best work never makes it into any record.</h1>
    <p style="font-size:1.25rem;color:#475569;margin-top:16px;">Groundwork is where that changes. Build an honest, two-sided record of a working relationship — before the hard conversation, not after.</p>
    <p style="margin-top:32px;">
      <a href="https://app.groundwork.app/register" style="background:#1d4ed8;color:#fff;padding:12px 24px;border-radius:8px;text-decoration:none;">Open your first ground — free</a>
    </p>
  </main>
</Layout>
