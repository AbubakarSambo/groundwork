---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://app.myground.work';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Groundwork · A clear picture of your most important work period</title>
<meta name="description" content="Groundwork gives a clear picture of your most important work period, from a clear beginning to a clear end. Everyone checks in privately. Groundwork shows where people agree, where they understand things differently, and where a conversation is needed, while there is still time to act." />
<link rel="canonical" href="https://myground.work" />
<meta name="robots" content="index, follow" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Groundwork" />
<meta property="og:title" content="Groundwork · A clear picture of your most important work period" />
<meta property="og:description" content="Everyone checks in privately. Groundwork shows where people agree, where they understand things differently, and where a conversation is needed, before it becomes a problem." />
<meta property="og:url" content="https://myground.work" />
<meta property="og:image" content="https://myground.work/og-image.png" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="Groundwork · A clear picture of your most important work period" />
<meta name="twitter:description" content="Everyone checks in privately. Groundwork shows where people agree, where they understand things differently, and where a conversation is needed, before it becomes a problem." />
<meta name="twitter:image" content="https://myground.work/og-image.png" />
<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Groundwork",
  "url": "https://myground.work",
  "description": "Groundwork gives a clear picture of your most important work period. Everyone checks in privately. It shows where people agree, where they understand things differently, and where a conversation is needed.",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
})}</script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

/* ── TOKENS ────────────────────────────────────────────────── */
#s-land{
  --c-navy:#0C447C;
  --c-navy-d:#0A1628;
  --c-teal:#5DCAA5;
  --c-amber:#E8A94A;
  --c-text:#1A1916;
  --c-sub:#6B6560;
  --c-muted:#9B9590;
  --c-border:#E2E0DB;
  --c-bg:#EDECEA;
  --c-off:#F5F3EF;
  --c-white:#FFFFFF;
  --font:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
}

body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:13px;color:#1A1916;min-height:100vh;background:#EDECEA;margin:0}

/* ── ANIMATIONS ────────────────────────────────────────────── */
@keyframes l-blink  {0%,100%{opacity:1}50%{opacity:0}}
@keyframes l-pulse  {0%,100%{box-shadow:0 0 0 0 rgba(93,202,165,.5)}50%{box-shadow:0 0 0 5px rgba(93,202,165,0)}}
@keyframes l-fadein {from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes l-up     {from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* ── NAV ───────────────────────────────────────────────────── */
.l-nav{
  position:sticky;top:0;z-index:100;
  background:rgba(237,236,234,.96);backdrop-filter:blur(8px);
  border-bottom:1px solid var(--c-border);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 20px;height:56px;
}
.l-nav-logo{display:flex;align-items:center;gap:9px;cursor:pointer;flex-shrink:0}
.l-nav-logo span{font-size:15px;font-weight:700;color:var(--c-navy);letter-spacing:-.02em}
.l-nav-links{display:flex;align-items:center;gap:2px}
.l-nav-link{
  font-size:13px;font-weight:500;color:var(--c-sub);background:none;border:none;
  cursor:pointer;padding:6px 11px;border-radius:6px;font-family:var(--font);
  transition:all .15s;white-space:nowrap;
}
.l-nav-link:hover{background:#E8E6E3;color:var(--c-text)}
.l-nav-link.active{color:var(--c-navy);font-weight:600}
.l-nav-ctas{display:flex;align-items:center;gap:8px;flex-shrink:0}
.l-btn-ghost{
  font-size:13px;font-weight:600;color:var(--c-navy);background:none;
  border:1px solid #B5D4F4;cursor:pointer;padding:7px 14px;border-radius:6px;
  font-family:var(--font);white-space:nowrap;text-decoration:none;display:inline-block;
}
.l-btn-ghost:hover{background:#EEF4FB}
.l-btn-solid{
  font-size:13px;font-weight:700;color:var(--c-white);background:var(--c-navy);
  border:none;cursor:pointer;padding:7px 14px;border-radius:6px;
  font-family:var(--font);white-space:nowrap;transition:background .15s;
  text-decoration:none;display:inline-block;
}
.l-btn-solid:hover{background:#1557A0}

/* ── HERO ──────────────────────────────────────────────────── */
.l-hero{
  position:relative;overflow:hidden;background:var(--c-navy-d);
  display:flex;align-items:center;
  padding:48px 20px;
}
.l-hero-inner{
  max-width:1080px;margin:0 auto;width:100%;
  display:block;
}
.l-hero-label{
  font-size:10px;font-weight:600;color:rgba(147,197,253,.65);
  text-transform:uppercase;letter-spacing:.14em;margin-bottom:20px;
}
.l-hero-h1{
  font-size:44px;font-weight:800;line-height:1.08;letter-spacing:-.04em;
  color:var(--c-white);margin:0 0 22px;min-height:160px;
}
.l-hero-sub{
  font-size:15px;color:rgba(255,255,255,.52);line-height:1.75;
  margin:0 0 10px;max-width:440px;
}
.l-hero-sub2{
  font-size:12px;color:rgba(255,255,255,.26);line-height:1.6;
  margin:0 0 40px;max-width:420px;
}
.l-hero-btns{display:flex;gap:10px;flex-wrap:wrap}
.l-scn-chip{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.18);color:rgba(255,255,255,0.88);font-family:var(--font);font-size:13px;font-weight:600;padding:8px 14px;border-radius:20px;cursor:pointer;transition:background .15s;text-decoration:none}
.l-scn-chip:hover{background:rgba(255,255,255,0.18)}
.l-hero-btn-p{
  padding:13px 24px;border-radius:6px;background:var(--c-navy);color:var(--c-white);
  font-size:14px;font-weight:700;border:none;cursor:pointer;font-family:var(--font);
  transition:background .15s;text-decoration:none;display:inline-block;
}
.l-hero-btn-p:hover{background:#1557A0}
.l-hero-btn-g{
  padding:13px 24px;border-radius:6px;background:rgba(255,255,255,.07);
  color:rgba(255,255,255,.8);font-size:14px;font-weight:600;
  border:1px solid rgba(255,255,255,.12);cursor:pointer;font-family:var(--font);
  transition:background .15s;text-decoration:none;display:inline-block;
}
.l-hero-btn-g:hover{background:rgba(255,255,255,.12)}

.l-learn-more{
  font-size:12px;color:rgba(255,255,255,.4);margin:18px 0 0;cursor:pointer;
}
.l-learn-more:hover{color:rgba(255,255,255,.65)}

/* Primary CTA attention cue: slow breathing glow + periodic sheen sweep */
@keyframes l-cta-breathe{
  0%,100%{ box-shadow:0 4px 14px rgba(12,68,124,.35), 0 0 0 0 rgba(147,197,253,0); }
  50%{ box-shadow:0 6px 22px rgba(12,68,124,.55), 0 0 0 6px rgba(147,197,253,.12); }
}
@keyframes l-cta-sheen{
  0%,16%{ left:-70%; } 32%{ left:130%; } 100%{ left:130%; }
}
.l-cta-pulse{ position:relative; overflow:hidden; animation:l-cta-breathe 2.8s ease-in-out infinite; }
.l-cta-pulse::after{
  content:''; position:absolute; top:0; left:-70%; width:45%; height:100%;
  background:linear-gradient(120deg, transparent, rgba(255,255,255,.4), transparent);
  transform:skewX(-20deg); pointer-events:none;
  animation:l-cta-sheen 5s ease-in-out infinite;
}
.l-cta-pulse:hover{ transform:translateY(-1px); animation-play-state:paused; }
@media(prefers-reduced-motion:reduce){
  .l-cta-pulse{ animation:none; }
  .l-cta-pulse::after{ display:none; }
}

/* ── FEED PANEL ────────────────────────────────────────────── */
.l-feed-panel{
  background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);
  border-radius:10px;overflow:hidden;
}
.l-feed-hdr{
  display:flex;align-items:center;justify-content:space-between;
  padding:11px 14px;border-bottom:1px solid rgba(255,255,255,.07);
  background:rgba(255,255,255,.03);
}
.l-mobile-checkin{display:none}
.l-feed-dot{
  width:7px;height:7px;border-radius:50%;background:#5DCAA5;
  display:inline-block;animation:l-pulse 2s ease-in-out infinite;flex-shrink:0;
}
.l-feed-body{min-height:230px;display:flex;flex-direction:column;justify-content:flex-end}
.l-feed-foot{
  display:grid;grid-template-columns:1fr 1fr 1fr;
  padding:10px 14px;border-top:1px solid rgba(255,255,255,.06);gap:4px;
}
.l-stat-val{font-size:17px;font-weight:700;color:var(--c-white);text-align:center;transition:color .4s}
.l-stat-lbl{font-size:9px;color:rgba(255,255,255,.28);text-align:center;margin-top:2px;letter-spacing:.02em}
.l-feed-item{
  animation:l-fadein .4s ease forwards;
  padding:8px 14px;border-bottom:1px solid rgba(255,255,255,.04);
}
.l-feed-item:last-child{border-bottom:none}

/* ── NET BG ────────────────────────────────────────────────── */
.l-net{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;opacity:.07}

/* ── SECTIONS ──────────────────────────────────────────────── */
.l-sec{width:100%}
.l-wrap{max-width:1080px;margin:0 auto;padding:48px 20px}
.l-wrap-sm{max-width:720px;margin:0 auto;padding:48px 20px}
.l-sec-label{
  font-size:10px;font-weight:600;color:var(--c-navy);
  text-transform:uppercase;letter-spacing:.14em;margin-bottom:18px;opacity:.65;
}
.l-sec-h2{font-size:36px;font-weight:800;color:var(--c-text);letter-spacing:-.03em;line-height:1.15;margin-bottom:14px}
.l-sec-p{font-size:15px;color:var(--c-sub);line-height:1.75;margin-bottom:40px;max-width:500px}

/* ── PROBLEM ───────────────────────────────────────────────── */
.l-prob-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;max-width:900px;margin:0 auto}
.l-prob-card{
  background:var(--c-white);border-radius:8px;border:1px solid var(--c-border);
  padding:16px 14px 16px 18px;position:relative;overflow:hidden;
}
.l-prob-card::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--c-navy);
}
.l-prob-title{font-size:13px;font-weight:700;color:var(--c-text);margin-bottom:4px}
.l-prob-desc{font-size:12px;color:var(--c-sub);line-height:1.55}

/* ── MOMENTS ───────────────────────────────────────────────── */
.l-mom-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.l-mom-card{
  background:var(--c-white);border-radius:10px;border:1px solid var(--c-border);
  padding:26px 22px;border-top-width:3px;
}
.l-mom-card.start{border-top-color:var(--c-navy)}
.l-mom-card.recog{border-top-color:var(--c-amber)}
.l-mom-card.align{border-top-color:var(--c-teal)}
.l-mom-badge{
  display:flex;align-items:center;gap:8px;margin-bottom:14px;
}
.l-mom-badge-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;animation:l-pulse 2.5s ease-in-out infinite}
.l-mom-badge span{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em}
.l-mom-h3{font-size:18px;font-weight:700;color:var(--c-text);margin-bottom:8px;letter-spacing:-.02em;line-height:1.3}
.l-mom-desc{font-size:13px;color:var(--c-sub);line-height:1.65;margin-bottom:14px}
.l-mom-item{display:flex;align-items:flex-start;gap:8px;font-size:12px;color:var(--c-sub);line-height:1.5;margin-bottom:5px}
.l-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;margin-top:5px}
.l-dot-navy{background:var(--c-navy)}
.l-dot-amber{background:var(--c-amber)}
.l-dot-teal{background:var(--c-teal)}

/* ── DEMO ──────────────────────────────────────────────────── */
.l-demo-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:10px;max-width:900px}
.l-demo-btn{
  display:flex;align-items:flex-start;gap:11px;padding:13px;border-radius:8px;
  background:var(--c-white);border:1px solid var(--c-border);cursor:pointer;
  font-family:var(--font);text-align:left;transition:all .15s;text-decoration:none;
}
.l-demo-btn:hover{border-color:#B5D4F4;background:#EEF4FB;transform:translateY(-1px)}
.l-demo-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:3px}
.l-demo-title{font-size:13px;font-weight:700;color:var(--c-text);margin-bottom:2px}
.l-demo-desc{font-size:12px;color:var(--c-muted);line-height:1.4}

/* ── TRUST ─────────────────────────────────────────────────── */
.l-trust-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
.l-trust-item{display:flex;align-items:flex-start;gap:12px;padding:13px 0;border-bottom:1px solid #E8E6E3}
.l-trust-item:last-child{border-bottom:none}
.l-trust-dot{width:6px;height:6px;border-radius:50%;background:var(--c-navy);flex-shrink:0;margin-top:5px}
.l-trust-strong{font-size:13px;font-weight:700;color:var(--c-text);display:block;margin-bottom:2px}
.l-trust-p{font-size:12px;color:var(--c-sub);line-height:1.55;margin:0}

/* ── PRICING ───────────────────────────────────────────────── */
.l-price-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:32px}
.l-price-card{border-radius:10px;padding:26px}
.l-price-card.free{background:var(--c-off);border:1px solid var(--c-border)}
.l-price-card.paid{background:var(--c-navy)}
.l-price-tier{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:14px}
.l-price-amt{font-size:34px;font-weight:800;margin-bottom:4px}
.l-price-sub{font-size:13px;margin-bottom:22px}
.l-price-item{display:flex;align-items:center;gap:7px;font-size:13px;margin-bottom:5px}

/* ── STEPS ─────────────────────────────────────────────────── */
.l-step{display:flex;gap:18px;padding:26px 0;border-bottom:1px solid #E8E6E3;align-items:flex-start}
.l-step:last-child{border-bottom:none}
.l-step-num{
  width:30px;height:30px;border-radius:50%;background:var(--c-navy);
  color:var(--c-white);display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:700;flex-shrink:0;margin-top:1px;
}
.l-step-title{font-size:15px;font-weight:700;color:var(--c-text);margin-bottom:5px;letter-spacing:-.01em}
.l-step-desc{font-size:13px;color:var(--c-sub);line-height:1.65}

/* ── CTA ───────────────────────────────────────────────────── */
.l-cta-sec{background:var(--c-navy-d);text-align:center;padding:80px 20px}
.l-cta-h2{font-size:40px;font-weight:800;color:var(--c-white);letter-spacing:-.04em;line-height:1.1;margin-bottom:14px}
.l-cta-p{font-size:16px;color:rgba(255,255,255,.4);margin-bottom:32px;font-style:italic}

/* ── FOOTER ────────────────────────────────────────────────── */
.l-footer{background:#091525;padding:36px 20px}
.l-footer-inner{max-width:1080px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}

/* ── SCROLL FADE ───────────────────────────────────────────── */
.l-fade{opacity:0;transform:translateY(18px);transition:opacity .5s ease,transform .5s ease}
.l-fade.in{opacity:1;transform:translateY(0)}

/* ══ TABLET (≤900px) ═══════════════════════════════════════════ */
@media(max-width:900px){
  .l-hero-inner{padding:44px 20px 40px}
  .l-hero-h1{font-size:36px;min-height:auto}
  .l-prob-grid{grid-template-columns:1fr 1fr;gap:12px}
  .l-mom-grid{grid-template-columns:1fr}
  .l-trust-grid{grid-template-columns:1fr;gap:32px}
  .l-price-grid{grid-template-columns:1fr}
  .l-wrap{padding:52px 20px}
  .l-wrap-sm{padding:52px 20px}
  .l-cta-h2{font-size:32px}
  .l-footer-inner{justify-content:center;text-align:center}
}

/* ══ MOBILE (≤620px) ═══════════════════════════════════════════ */
@media(max-width:620px){
  /* Nav - keep both buttons, hide page links */
  .l-nav{padding:0 14px;height:52px}
  .l-nav-links{display:none}
  .l-btn-ghost{font-size:12px;padding:6px 10px}
  .l-btn-solid{font-size:12px;padding:6px 10px}

  /* Hero - mobile */
  .l-hero{padding:0}
  .l-hero-inner{padding:28px 16px 24px}
  .l-hero-label{font-size:9px;margin-bottom:10px}
  .l-hero-h1{font-size:20px !important;min-height:auto;margin-bottom:10px !important}
  .l-hero-sub{font-size:13px;margin-bottom:6px;max-width:100%}
  .l-hero-sub2{display:none}
  /* hero subtext smaller on mobile */
  .l-hero-inner p{font-size:14px !important;margin-bottom:16px !important}

  /* Primary CTAs - primary full width, sign in text link */
  .l-hero-btns{flex-direction:column;gap:8px;margin-bottom:0}
  .l-hero-btn-p{
    width:100%;text-align:center;padding:13px 14px;
    font-size:14px;border-radius:8px;
  }
  .l-hero-btn-g{
    width:100%;text-align:center;padding:8px 14px;
    font-size:13px;border-radius:8px;
    background:transparent !important;border-color:rgba(255,255,255,0.15) !important;
  }

  /* Mobile check-in CTA - additional prominent button */
  .l-mobile-checkin{
    display:block !important;
    width:100%;padding:16px 20px;margin-bottom:24px;
    border-radius:8px;background:rgba(255,255,255,.1);
    color:white;font-size:15px;font-weight:600;
    border:1px solid rgba(255,255,255,.2);
    cursor:pointer;font-family:var(--font);
    text-align:center;
  }

  /* Feed panel on mobile - compact, card-like */
  .l-feed-panel{
    border-radius:10px 10px 0 0;
    border-left:none;border-right:none;border-bottom:none;
    margin:0 -16px;
  }
  .l-feed-body{min-height:180px}

  /* Sections */
  .l-wrap{padding:32px 16px}
  .l-wrap-sm{padding:32px 16px}
  /* Description section: left-align, smaller text on mobile */
  .l-what-desc{font-size:13px !important;text-align:left !important;line-height:1.7 !important}
  .l-what-list{text-align:left !important;font-size:12px !important}
  .l-sec-h2{font-size:26px}
  .l-sec-label{font-size:9px}

  /* Problem */
  .l-prob-grid{grid-template-columns:1fr}

  /* Demo */
  .l-demo-grid{grid-template-columns:1fr}

  /* Steps */
  .l-step{padding:20px 0;gap:14px}
  .l-step-title{font-size:14px}
  .l-step-desc{font-size:13px}

  /* Pricing */
  .l-price-grid{grid-template-columns:1fr}

  /* CTA */
  .l-cta-sec{padding:56px 16px}
  .l-cta-h2{font-size:26px}

  /* Footer */
  .l-footer{padding:28px 16px}
  .l-footer-inner{flex-direction:column;align-items:center;text-align:center;gap:14px}
  .l-footer-links{justify-content:center}
}

/* ══ SMALL MOBILE (≤380px) ═════════════════════════════════════ */
@media(max-width:380px){
  .l-hero-h1{font-size:24px}
  .l-sec-h2{font-size:22px}
  .l-cta-h2{font-size:22px}
  .l-prob-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<div id="s-land" style="background:#EDECEA;color:#1A1916">

<!-- ══ NAV ════════════════════════════════════════════════════════════════ -->
<nav class="l-nav">
  <div class="l-nav-logo" onclick="scrollTo(0,0)">
    <svg width="20" height="16" viewBox="0 0 22 17" fill="none">
      <rect x="5"  y="0"  width="12" height="3" rx="1.5" fill="#0C447C" opacity="0.45"/>
      <rect x="2"  y="6"  width="18" height="3" rx="1.5" fill="#0C447C" opacity="0.72"/>
      <rect x="0"  y="12" width="22" height="3" rx="1.5" fill="#0C447C"/>
    </svg>
    <span>Groundwork</span>
  </div>
  <div class="l-nav-links">
    <button class="l-nav-link active" onclick="lNav('home')">Home</button>
    <button class="l-nav-link" onclick="lNav('how')">How it works</button>
    <button class="l-nav-link" onclick="lNav('usecases')">Use cases</button>
    <button class="l-nav-link" onclick="lNav('pricing')">Pricing</button>
    <button class="l-nav-link" onclick="lNav('about')">About</button>
  </div>
  <div class="l-nav-ctas">
    <a class="l-btn-ghost" href={`${APP_URL}/auth?mode=member`}>Sign in</a>
    <a class="l-btn-solid" href={`${APP_URL}/start`}>Get started</a>
  </div>
</nav>

<!-- ══ PAGES ══════════════════════════════════════════════════════════════ -->

<!-- HOME PAGE -->
<div id="lp-home">

  <!-- HERO -->
  <div class="l-hero">
