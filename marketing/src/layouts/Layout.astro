---
const {
  title = 'Groundwork',
  description = 'Groundwork builds a shared picture from what everyone involved has seen, agreed, and committed to. Each person checks in independently. The report shows where you align and where you differ.',
  canonicalPath = '',
} = Astro.props;
const SITE = 'https://myground.work';
const canonical = `${SITE}${canonicalPath}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Groundwork" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${SITE}/og-image.png`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE}/og-image.png`} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Groundwork",
      "url": SITE,
      "description": description,
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    })} />

    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <slot />

    <!-- Feedback widget -->
    <style>
      #gw-fb-trigger{position:fixed;bottom:20px;right:20px;z-index:9000;display:flex;flex-direction:column;align-items:center;gap:3px}
      #gw-fb-btn{width:44px;height:44px;border-radius:50%;background:#0C447C;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:white;box-shadow:0 2px 12px rgba(0,0,0,.18);transition:transform .12s,box-shadow .12s;font-family:inherit}
      #gw-fb-btn:hover{transform:scale(1.06);box-shadow:0 4px 16px rgba(0,0,0,.22)}
      #gw-fb-label{font-size:10px;color:#6B6560;font-weight:500;letter-spacing:.02em;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
      #gw-fb-panel{position:fixed;bottom:80px;right:20px;width:300px;background:white;border:1px solid #E2E0DB;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.14);z-index:8999;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;display:none}
      #gw-fb-panel.open{display:block}
      .gw-fb-tabs{display:flex;border-bottom:1px solid #E2E0DB;padding:0 4px}
      .gw-fb-tab{flex:1;padding:10px 4px;font-size:11px;font-weight:500;color:#6B6560;background:none;border:none;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;font-family:inherit;transition:color .12s}
      .gw-fb-tab.active{color:#0C447C;border-bottom-color:#0C447C;font-weight:700}
      .gw-fb-body{padding:14px}
      .gw-fb-heading{font-size:13px;font-weight:700;color:#1A1916;margin-bottom:12px}
      .gw-fb-pills{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px}
      .gw-fb-pill{font-size:11.5px;padding:5px 10px;border-radius:20px;border:1px solid #E2E0DB;background:white;color:#4A5568;cursor:pointer;font-family:inherit;transition:all .1s}
      .gw-fb-pill:hover{border-color:#0C447C;color:#0C447C}
      .gw-fb-pill.sel{background:#0C447C;border-color:#0C447C;color:white}
      .gw-fb-opt{font-size:10px;color:#9B9590;margin-bottom:4px}
      .gw-fb-textarea{width:100%;box-sizing:border-box;padding:8px 10px;font-size:12px;border:1px solid #E2E0DB;border-radius:6px;resize:none;font-family:inherit;outline:none;line-height:1.5;color:#1A1916}
      .gw-fb-textarea:focus{border-color:#0C447C}
      .gw-fb-send{width:100%;margin-top:10px;padding:9px;background:#0C447C;color:white;border:none;border-radius:6px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit}
      .gw-fb-send:disabled{opacity:.4;cursor:not-allowed}
      .gw-fb-note{font-size:11px;color:#9B9590;margin-top:8px;text-align:center}
      .gw-fb-confirm{padding:24px 14px;text-align:center;font-size:13px;color:#1A1916;font-weight:500}
      .gw-fb-error{font-size:11.5px;color:#c0392b;margin-top:6px;text-align:center}
    </style>

    <div id="gw-fb-trigger">
      <button id="gw-fb-btn" aria-label="Open feedback">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M2 2h14a1 1 0 011 1v9a1 1 0 01-1 1H6l-4 3V3a1 1 0 011-1z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>
      </button>
      <span id="gw-fb-label">Feedback</span>
    </div>

    <div id="gw-fb-panel">
      <div id="gw-fb-inner"></div>
    </div>

    <script>
      (function() {
        const API = 'https://api.myground.work/api/v1';
        const TABS = ['reaction','build_request','something_went_wrong'];
        const TAB_LABELS = {reaction:'Reaction',build_request:'Build request',something_went_wrong:'Something went wrong'};
        const HEADINGS = {reaction:'How does this feel?',build_request:'What would you build?',something_went_wrong:'What went wrong?'};
        const PILLS = {
          reaction:['This is exactly what I needed.','This could work for me.','Interesting but not sure yet.','Not built for my situation.','Too much to take in.','I do not trust it yet.','This feels like it matters.','I would not use this.','Other.'],
          build_request:['Add a feature.','Change something that exists.','This works but needs to be simpler.','Build this for my specific situation.'],
          something_went_wrong:['Something did not load.','I got an error.','The page behaved unexpectedly.','Something else.']
        };
        const TEXT_REQUIRED = {reaction:false,build_request:true,something_went_wrong:true};

        let open = false, tab = 'reaction', pill = null, confirmed = false;

        const btn = document.getElementById('gw-fb-btn');
        const panel = document.getElementById('gw-fb-panel');
        const inner = document.getElementById('gw-fb-inner');

        function render() {
          if (confirmed) {
            inner.innerHTML = '<div class="gw-fb-confirm">Your feedback was received. Thank you.</div>';
            return;
          }
          const tabsHtml = TABS.map(t =>
            `<button class="gw-fb-tab${t===tab?' active':''}" data-tab="${t}">${TAB_LABELS[t]}</button>`
          ).join('');
          const pillsHtml = PILLS[tab].map(p =>
            `<button class="gw-fb-pill${p===pill?' sel':''}" data-pill="${p}">${p}</button>`
          ).join('');
          inner.innerHTML = `
            <div class="gw-fb-tabs">${tabsHtml}</div>
            <div class="gw-fb-body">
              <div class="gw-fb-heading">${HEADINGS[tab]}</div>
              <div class="gw-fb-pills">${pillsHtml}</div>
              <div class="gw-fb-opt">${TEXT_REQUIRED[tab]?'Description (required)':'Add a note (optional)'}</div>
              <textarea class="gw-fb-textarea" rows="3" id="gw-fb-text"></textarea>
              <button class="gw-fb-send" id="gw-fb-send-btn" ${!pill?'disabled':''}>Send</button>
              <div id="gw-fb-error" class="gw-fb-error" style="display:none"></div>
              <div class="gw-fb-note">Your response is anonymous.</div>
            </div>`;

          inner.querySelectorAll('.gw-fb-tab').forEach(el => el.addEventListener('click', () => { tab = el.dataset.tab; pill = null; render(); }));
          inner.querySelectorAll('.gw-fb-pill').forEach(el => el.addEventListener('click', () => { pill = el.dataset.pill; render(); }));
          const sendBtn = document.getElementById('gw-fb-send-btn');
          const textEl = document.getElementById('gw-fb-text');
          textEl.addEventListener('input', () => { sendBtn.disabled = !pill || (TEXT_REQUIRED[tab] && !textEl.value.trim()); });
          sendBtn.addEventListener('click', async () => {
            const text = textEl.value.trim();
            const errEl = document.getElementById('gw-fb-error');
            if (TEXT_REQUIRED[tab] && !text) { errEl.style.display=''; errEl.textContent='Please add a description before sending.'; return; }
            sendBtn.disabled = true; sendBtn.textContent = 'Sending…';
            try {
              await fetch(`${API}/feedback`, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({tab, pill, text: text||undefined, source:'marketing'}) });
              confirmed = true; render();
              setTimeout(() => { confirmed=false; tab='reaction'; pill=null; open=false; panel.classList.remove('open'); updateBtnIcon(); }, 2800);
            } catch { sendBtn.disabled=false; sendBtn.textContent='Send'; errEl.style.display=''; errEl.textContent='Could not send. Please try again.'; }
          });
        }

        function updateBtnIcon() {
          btn.innerHTML = open
            ? '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>'
            : '<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M2 2h14a1 1 0 011 1v9a1 1 0 01-1 1H6l-4 3V3a1 1 0 011-1z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>';
        }

        btn.addEventListener('click', () => {
          open = !open;
          panel.classList.toggle('open', open);
          if (open) render();
          updateBtnIcon();
        });
      })();
    </script>
  </body>
</html>
