// Groundwork — contribution intelligence platform
// Core unit is a "Ground" (an alignment ground): one situation, two parties,
// building toward one defined decision. See README for the product model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN // manages grounds, billing activation, sees the alignment feed
  MEMBER // a regular person who checks in
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_SETUP
  PASSWORD_RESET
  PARTICIPANT_INVITE // magic link for a participant added to a ground
}

enum CareFeeStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELLED
}

// The six entry states collapse into the scenario the initiator selects.
enum GroundScenario {
  NEW_HIRE
  NEW_COFOUNDER
  NEW_ADVISOR
  NEW_PROJECT
  NEW_MANAGER
  CONTRACT_RENEWAL
  RECOGNITION
  DRIFT
  CRISIS_ALIGNMENT
  OKR_ALIGNMENT
  WORKPLAN_BUDGET
  PULSE_CHECK
  REALIGN_TEAM
  PIP
  BOARD_STRATEGY
  COHORT_CHECK
}

// Three moments from the conversation design.
enum GroundMoment {
  STARTING
  RECOGNITION
  RESOLUTION
}

enum GroundStatus {
  AWAITING_LEAD // admin created this for a lead; lead invited but has not confirmed yet
  OPEN // created, parties may not all be added
  AWAITING_PARTIES // waiting on check-ins
  REPORT_READY // both completed session 2, report locked behind paywall
  ACTIVE // admin activated -> billing running
  PAUSED // temporarily paused (e.g. active legal proceedings detected)
  RESOLVED // both confirmed an end state
  STALLED // full period elapsed with no resolution
  CLOSED // permanent record, billing stopped
}

enum PartyType {
  INITIATOR // opened the ground
  PARTICIPANT // added by the initiator; never sees the initiator's record
}

enum CheckInStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DECLINED // willingness gate answered no — itself a useful record
}

enum TurnRole {
  AI
  PERSON
}

// Structured data extracted from a check-in. Belongs to the person.
enum RecordEntryType {
  SUCCESS_DEFINITION
  COMMITMENT
  ASK
  INTENT
  TOLERANCE
  WORRY
  TENSION
}

// Three-period rule: CANDIDATE until observed in 3 consecutive periods.
enum PatternStatus {
  CANDIDATE
  SURFACED
}

enum Cadence {
  DAILY
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  SEQUENTIAL // no fixed schedule: the initiator's check-in opens the team's next round
}

enum BillingEventType {
  CARE_FEE         // $25/month/account (platform fee)
  PARTICIPANT_FEE  // $25/unique participant/month across active grounds
  SESSION_FEE      // $5 per additional session
  SUBSCRIPTION_FEE // org subscription (Starter/SmallTeam/Growth/Business/Enterprise)
  FREE_EXTENSION   // one-time free session extension per org
}

enum SubscriptionPlan {
  STARTER     // up to 5 people, $25/mo
  SMALL_TEAM  // up to 20 people, $50/mo
  GROWTH      // up to 100 people, $100/mo
  BUSINESS    // up to 250 people, $200/mo
  SCALE       // up to 1,000 people, $400/mo
  ENTERPRISE  // unlimited, contact sales
}

enum EvidenceType {
  DOCUMENT_AT_AGREEMENT
  DOCUMENT_AFTER
  CHECK_IN
  ANCHORED_RECALL
  UNANCHORED_RECALL
}

enum BillingEventStatus {
  PENDING
  PAID
  FAILED
}

enum CompanyStage {
  IDEA
  PRE_REVENUE
  EARLY_REVENUE
  SCALING
}

// ---------------------------------------------------------------------------
// Identity & tenancy
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  email     String?

  // Billing (Stripe, USD). Care fee is the always-on commitment device.
  stripeCustomerId       String?       @map("stripe_customer_id")
  careFeeStatus          CareFeeStatus @default(NONE) @map("care_fee_status")
  careFeeSubscriptionId  String?       @map("care_fee_subscription_id")
  defaultPaymentMethodId String?       @map("default_payment_method_id")
  gracePeriodUntil       DateTime?     @map("grace_period_until")
  freeSessionsUsed   Int     @default(0)     @map("free_sessions_used")
  firstGroundUsed    Boolean @default(false) @map("first_ground_used")
  freeExtensionUsed  Boolean @default(false) @map("free_extension_used")
  allowCodeCreation  Boolean @default(false) @map("allow_code_creation")

  // Org subscription
  subscriptionPlan      SubscriptionPlan? @map("subscription_plan")
  subscriptionStatus    String?           @map("subscription_status") // active | paused | cancelled
  subscriptionStripeId  String?           @map("subscription_stripe_id")
  subscriptionPeriodEnd DateTime?         @map("subscription_period_end")

  companyStage CompanyStage? @map("company_stage")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users            User[]
  grounds          Ground[]
  billingEvents    BillingEvent[]
  orgIntelligence  OrgIntelligence[]
  contributorCodes ContributorCode[]

  @@map("organizations")
}

model User {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  email           String   @unique
  passwordHash    String?  @map("password_hash")
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  jobTitle        String?  @map("job_title")
  role            UserRole @default(MEMBER)
  isActive        Boolean  @default(true) @map("is_active")
  isEmailVerified Boolean  @default(false) @map("is_email_verified")
  isPlatformAdmin      Boolean  @default(false) @map("is_platform_admin")
  googleId             String?  @unique @map("google_id")
  emailNotifications   Boolean  @default(true) @map("email_notifications")
  // E.164 format (e.g. "+2348012345678"). Global uniqueness - one Groundwork
  // WhatsApp number serves everyone, so a phone number identifies exactly one
  // account, not one per org. Set by the user in Settings, or by an
  // admin/HR adding it on someone's behalf via the org roster.
  phoneNumber          String?  @unique @map("phone_number")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization             Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  tokens                   EmailVerificationToken[]
  groundsInitiated         Ground[]                   @relation("GroundInitiator")
  participantLinks         GroundParticipant[]
  disclaimerAcknowledgements DisclaimerAcknowledgement[]
  adminProfile             AdminProfile?
  contributorCodes         ContributorCode[]          @relation("ContributorCodes")
  redeemedCodes            ContributorCode[]          @relation("RedeemedCodes")
  codeRedemptions          ContributorCodeRedemption[] @relation("CodeRedemptions")

  @@index([organizationId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Per-admin preference profile — built from past grounds, used to deepen
// probing on new grounds. Never used to skip questions.
// ---------------------------------------------------------------------------
model AdminProfile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  signals   Json     @default("[]") // string[] of observed preference signals
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  type      TokenType
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// ---------------------------------------------------------------------------
// The Ground — the core transactional unit
// ---------------------------------------------------------------------------

model Ground {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  initiatorId    String         @map("initiator_id")
  scenario       GroundScenario
  moment         GroundMoment
  status         GroundStatus   @default(OPEN)
  label          String

  timelineDays  Int     @map("timeline_days")
  timelineWeeks Int?    @map("timeline_weeks")
  cadence       Cadence @default(FORTNIGHTLY)
  cadenceAnchorDay Int? @map("cadence_anchor_day") // weekly: 0=Sun..6=Sat ("every Monday"); monthly: 1-31 (day of month)
  startsAt      DateTime? @map("starts_at") // when the first scheduled check-in opens (start date)
  endsAt        DateTime? @map("ends_at")   // no new check-ins scheduled after this (end date)
  endState      String? @map("end_state") // the decision the process worked toward
  resolutionState String? @map("resolution_state") // pre-agreed intended outcome set at creation
  brief           String? @map("brief") // initiator's opening brief, written at ground creation
  groundAuditLog Json?  @map("ground_audit_log") // append-only JSON log of timeline/cadence changes
  createdByUserId String? @map("created_by_user_id") // the admin who set this up for a lead; null for self-serve grounds

  // Lifecycle / billing markers
  billingActivatedAt  DateTime? @map("billing_activated_at") // admin activated report
  billingEnabled      Boolean   @default(false) @map("billing_enabled")
  paymentConfirmed    Boolean   @default(false) @map("payment_confirmed")
  resolvedAt          DateTime? @map("resolved_at")
  closedAt            DateTime? @map("closed_at")
  pausedAt            DateTime? @map("paused_at") // set when status transitions to PAUSED

  sessionsBalance     Int     @default(1) @map("sessions_balance")
  isFreeGround        Boolean @default(true) @map("is_free_ground")
  accessCodeId        String? @map("access_code_id")
  freeReason          String? @map("free_reason")  // "FIRST_GROUND" | "ACCESS_CODE"
  freeParticipantCap  Int     @default(4) @map("free_participant_cap")
  joinToken           String? @unique @map("join_token")

  promptVersionId     String? @map("prompt_version_id")
  stripeScenarioSubId String? @map("stripe_scenario_sub_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization             Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  initiator                User                       @relation("GroundInitiator", fields: [initiatorId], references: [id])
  promptVersion            PromptVersion?             @relation(fields: [promptVersionId], references: [id])
  accessCode               ContributorCode?           @relation("GroundAccessCode", fields: [accessCodeId], references: [id])
  participants             GroundParticipant[]
  checkIns                 CheckIn[]
  report                   Report?
  patternDetections        PatternDetection[]
  resolution               Resolution?
  outcome                  Outcome?
  outcomeFeedback          OutcomeFeedback[]
  billingEvents            BillingEvent[]
  documents                GroundDocument[]
  leadContextNotes         LeadContextNote[]
  disclaimerAcknowledgements DisclaimerAcknowledgement[]
  reportActivations          ReportActivation[]
  participantRequests        ParticipantRequest[]
  contributorCodeRedemptions ContributorCodeRedemption[]

  @@index([organizationId])
  @@index([status])
  @@map("grounds")
}

model GroundParticipant {
  id                 String    @id @default(uuid())
  groundId           String    @map("ground_id")
  userId             String?   @map("user_id") // null until they accept the invite
  email              String
  partyType          PartyType
  roleAsDescribed    String?   @map("role_as_described") // role as the initiator described it
  willingnessEvidence  Boolean? @map("willingness_evidence") // willingness gate Q1
  willingnessCadence   Boolean? @map("willingness_cadence") // willingness gate Q2
  invitedAt          DateTime? @map("invited_at")
  notifiedAt         DateTime? @map("notified_at") // never added silently
  // Magic-link invite (cleared once accepted; userId is set on accept).
  inviteToken          String?   @unique @map("invite_token")
  inviteTokenExpiresAt DateTime? @map("invite_token_expires_at")
  // Rolling specificity scores (Agent 1) used for trust calibration / tone.
  specificityHistory   Float[]   @default([]) @map("specificity_history")
  lastNudgedAt         DateTime? @map("last_nudged_at") // throttles reminder emails (B1)
  soloArtifact         String?   @db.Text @map("solo_artifact") // single-party record summary after session 1 (B2)
  soloArtifactAt       DateTime? @map("solo_artifact_at")
  soloArtifactShared   Boolean   @default(false) @map("solo_artifact_shared") // whether participant chose to share their individual report
  foundingIntent      String? @db.Text @map("founding_intent")
  roleIntent          String? @db.Text @map("role_intent")
  personalIntent      String? @db.Text @map("personal_intent")
  exitIntent          String? @db.Text @map("exit_intent")
  compensationAsk     String? @db.Text @map("compensation_ask")
  autonomyAsk         String? @db.Text @map("autonomy_ask")
  recognitionAsk      String? @db.Text @map("recognition_ask")
  growthAsk           String? @db.Text @map("growth_ask")
  relationshipAsk     String? @db.Text @map("relationship_ask")
  financialFloor      String? @db.Text @map("financial_floor")
  stressTolerance     String? @db.Text @map("stress_tolerance")
  relationalTolerance String? @db.Text @map("relational_tolerance")
  createdAt          DateTime  @default(now()) @map("created_at")

  ground            Ground             @relation(fields: [groundId], references: [id], onDelete: Cascade)
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  checkIns          CheckIn[]
  recordEntries     RecordEntry[]
  patternDetections PatternDetection[]
  outcomeFeedback   OutcomeFeedback[]
  documents         GroundDocument[]
  leadContextNotes  LeadContextNote[]
  resolutionConfirmations ResolutionConfirmation[]
  reportActivations       ReportActivation[]

  @@unique([groundId, email])
  @@index([groundId])
  @@map("ground_participants")
}

// ---------------------------------------------------------------------------
// Conversation — each party checks in INDEPENDENTLY. Never cross-readable.
// ---------------------------------------------------------------------------

model CheckIn {
  id            String        @id @default(uuid())
  groundId      String        @map("ground_id")
  participantId String        @map("participant_id")
  sessionNumber Int           @map("session_number") // 1, 2, ...
  status        CheckInStatus @default(NOT_STARTED)
  availableFrom DateTime?     @map("available_from") // cadence gate — session 2+ opens after this date
  startedAt     DateTime?     @map("started_at")
  completedAt    DateTime?     @map("completed_at")
  warningFiredAt DateTime?     @map("warning_fired_at")
  sessionReadyNotifiedAt DateTime? @map("session_ready_notified_at") // one-shot: "your check-in is now open" email sent
  patternsAnalyzedAt DateTime? @map("patterns_analyzed_at") // pattern sweep has processed this period
  nextCommitment String?       @map("next_commitment")
  closedReason  String?        @map("closed_reason") // e.g. "willingness_declined"
  willingnessConfirmed Boolean @default(true) @map("willingness_confirmed") // willingness gate result
  specificityLevel     String?  @map("specificity_level")
  specificityDimensions Json?   @map("specificity_dimensions")
  recallConfidence     String?  @map("recall_confidence")
  isClarification      Boolean  @default(false) @map("is_clarification") // true when session is correcting a flagged inference
  clarificationTarget  String?  @map("clarification_target") // inference id from report.inferences being corrected
  isSelfCorrection     Boolean  @default(false) @map("is_self_correction") // true when session is correcting the participant's OWN prior session
  selfCorrectionTargetSession Int? @map("self_correction_target_session") // the session number being corrected
  createdAt     DateTime      @default(now()) @map("created_at")

  ground        Ground            @relation(fields: [groundId], references: [id], onDelete: Cascade)
  participant   GroundParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  turns         ConversationTurn[]
  recordEntries RecordEntry[]

  @@unique([participantId, sessionNumber])
  @@index([groundId])
  @@map("check_ins")
}

model ConversationTurn {
  id        String   @id @default(uuid())
  checkInId String   @map("check_in_id")
  role      TurnRole
  content   String   @db.Text
  stage     String? // which conversation stage produced this turn
  createdAt DateTime @default(now()) @map("created_at")

  checkIn CheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)

  @@index([checkInId])
  @@map("conversation_turns")
}

model RecordEntry {
  id            String          @id @default(uuid())
  participantId String          @map("participant_id")
  checkInId     String?         @map("check_in_id")
  type          RecordEntryType
  evidenceType  EvidenceType    @default(CHECK_IN)
  text          String          @db.Text // the person's exact words where possible
  recallBased   Boolean         @default(true) @map("recall_based") // false = anchored to a document
  dimensionThreadKey String?    @map("dimension_thread_key") // groups entries across sessions by theme
  anchored_question_id String?  @map("anchored_question_id") // which verbatim question produced this entry
  createdAt     DateTime        @default(now()) @map("created_at")

  participant GroundParticipant @relation(fields: [participantId], references: [id], onDelete: Restrict)
  checkIn     CheckIn?          @relation(fields: [checkInId], references: [id], onDelete: SetNull)

  @@index([participantId])
  @@map("record_entries")
}

// ---------------------------------------------------------------------------
// The Report — the shared picture. Released to BOTH parties simultaneously.
// ---------------------------------------------------------------------------

model Report {
  id              String    @id @default(uuid())
  groundId        String    @unique @map("ground_id")
  sharedPicture   String    @db.Text @map("shared_picture")
  agreements      Json // where both accounts agree
  divergences     Json // the gap — never framed as one side being right
  centralQuestion String    @db.Text @map("central_question")
  engagement      Json? // engagement-quality + confidence header: per-party session counts, % document-backed, coverage band (B4)
  inferences      Json?     // array of { id, text, participantId, sessionNumber } — items the AI inferred rather than directly quoted
  promptVersionId String?   @map("prompt_version_id")
  releasedAt      DateTime? @map("released_at") // set once, atomically, for both
  createdAt       DateTime  @default(now()) @map("created_at")

  ground        Ground         @relation(fields: [groundId], references: [id], onDelete: Cascade)
  promptVersion PromptVersion? @relation(fields: [promptVersionId], references: [id])

  @@map("reports")
}

// ---------------------------------------------------------------------------
// Participant requests — suggested by existing participants to the initiator
// ---------------------------------------------------------------------------

enum ParticipantRequestStatus {
  PENDING
  APPROVED
  DISMISSED
}

model ParticipantRequest {
  id               String                   @id @default(uuid())
  groundId         String                   @map("ground_id")
  requestedByEmail String                   @map("requested_by_email")
  requestedEmail   String                   @map("requested_email")
  requestedName    String?                  @map("requested_name")
  reason           String                   @db.Text
  status           ParticipantRequestStatus @default(PENDING)
  createdAt        DateTime                 @default(now()) @map("created_at")

  ground Ground @relation(fields: [groundId], references: [id], onDelete: Cascade)

  @@index([groundId])
  @@map("participant_requests")
}

// ---------------------------------------------------------------------------
// Pattern detection — behavioural signals, NEVER verdicts. Three-period rule.
// ---------------------------------------------------------------------------

model PatternDetection {
  id              String        @id @default(uuid())
  groundId        String        @map("ground_id")
  participantId   String        @map("participant_id")
  code            String // D1..D8, B1..B12, K/E/R/F codes — see Part 4
  periodsObserved Int           @default(1) @map("periods_observed")
  lastPeriodNumber Int?         @map("last_period_number") // session number of the most recent period; enforces consecutiveness
  status          PatternStatus @default(CANDIDATE)
  observationText String?       @db.Text @map("observation_text") // plain language, never a score
  // Accuracy feedback: did the admin or participant confirm this was accurate?
  accuracyRating  Boolean?      @map("accuracy_rating") // true = accurate, false = inaccurate, null = not yet rated
  ratedAt         DateTime?     @map("rated_at")
  ratedBy         String?       @map("rated_by") // userId of rater
  firstSeenAt     DateTime      @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime      @default(now()) @map("last_seen_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  ground      Ground            @relation(fields: [groundId], references: [id], onDelete: Cascade)
  participant GroundParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, code])
  @@index([groundId])
  @@index([code, accuracyRating]) // for per-code accuracy aggregation
  @@map("pattern_detections")
}

// ---------------------------------------------------------------------------
// Resolution — a ground closes only when BOTH parties confirm an end state.
// ---------------------------------------------------------------------------

model Resolution {
  id             String    @id @default(uuid())
  groundId       String    @unique @map("ground_id")
  endState       String    @map("end_state") // latest leading proposal; the agreed end state once closed
  decisionRights Json?     @map("decision_rights")
  closedAt       DateTime? @map("closed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  ground        Ground                   @relation(fields: [groundId], references: [id], onDelete: Cascade)
  confirmations ResolutionConfirmation[]

  @@map("resolutions")
}

// Per-party end-state confirmation. A ground closes only when every ACTIVE party
// (one who accepted their invite) has confirmed the SAME end state. For two-party
// grounds this is exactly the old "both confirm" behaviour; for project / team
// grounds it generalises to N parties.
model ResolutionConfirmation {
  id            String   @id @default(uuid())
  resolutionId  String   @map("resolution_id")
  participantId String   @map("participant_id")
  endState      String   @map("end_state")
  confirmedAt   DateTime @default(now()) @map("confirmed_at")

  resolution  Resolution        @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  participant GroundParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([resolutionId, participantId])
  @@index([resolutionId])
  @@map("resolution_confirmations")
}

// ---------------------------------------------------------------------------
// The moat: versioned prompts + outcome data + anonymised cross-org learning
// ---------------------------------------------------------------------------

model PromptVersion {
  id          String    @id @default(uuid())
  key         String // e.g. "system", "report_synthesis", "scenario.drift"
  version     Int
  content     String    @db.Text
  summary     String?   @db.Text // change summary — every change is logged
  isActive    Boolean   @default(false) @map("is_active")
  activatedAt DateTime? @map("activated_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  grounds Ground[]
  reports Report[]

  @@unique([key, version])
  @@map("prompt_versions")
}

model Outcome {
  id              String        @id @default(uuid())
  groundId        String        @unique @map("ground_id")
  promptVersionId String?       @map("prompt_version_id")
  resolvedState   String        @map("resolved_state")
  moment          GroundMoment? // the data point: prompt version, moment, end state, session count
  sessionCount    Int?          @map("session_count")
  resolvable      Boolean? // learning signal: was this resolvable at session 1?
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")

  ground Ground @relation(fields: [groundId], references: [id], onDelete: Cascade)

  @@index([promptVersionId])
  @@map("outcomes")
}

// Post-resolution feedback from each party: did this process help you reach a
// decision that felt fair and grounded in evidence? The seed of the learning loop.
model OutcomeFeedback {
  id            String   @id @default(uuid())
  groundId      String   @map("ground_id")
  participantId String   @map("participant_id")
  feltFair      Boolean  @map("felt_fair")
  note          String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  ground      Ground            @relation(fields: [groundId], references: [id], onDelete: Cascade)
  participant GroundParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([groundId, participantId])
  @@index([groundId])
  @@map("outcome_feedback")
}

model OrgIntelligence {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  patternSummary Json     @map("pattern_summary") // anonymised — no PII, no names
  anonymised     Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@map("org_intelligence")
}

model PatternBenchmark {
  id               String        @id @default(uuid())
  code             String
  orgStage         CompanyStage? @map("org_stage")
  teamSizeRange    String?       @map("team_size_range")
  outcomeType      String        @map("outcome_type")
  periodsToOutcome Int           @map("periods_to_outcome")
  moment           GroundMoment?
  createdAt        DateTime      @default(now()) @map("created_at")

  @@map("pattern_benchmarks")
}

model BillingEvent {
  id             String             @id @default(uuid())
  organizationId String             @map("organization_id")
  groundId       String?            @map("ground_id")
  type           BillingEventType
  amountCents    Int                @map("amount_cents")
  currency       String             @default("USD")
  periodStart    DateTime           @map("period_start")
  periodEnd      DateTime           @map("period_end")
  stripeInvoiceId String?           @map("stripe_invoice_id")
  status         BillingEventStatus @default(PENDING)
  createdAt      DateTime           @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ground       Ground?      @relation(fields: [groundId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("billing_events")
}

model ContributorCode {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  code            String    @unique
  sessionsGranted Int       @default(1) @map("sessions_granted")
  sessionsUsed    Int       @default(0) @map("sessions_used")
  createdByUserId  String    @map("created_by_user_id")
  note             String?   // optional label for the admin (e.g. "for the marketing team")
  allowCodeCreation Boolean  @default(false) @map("allow_code_creation")
  isActive          Boolean  @default(true)  @map("is_active")
  parentCodeId      String?  @map("parent_code_id")
  redeemedByUserId  String?  @map("redeemed_by_user_id")
  expiresAt         DateTime @default(dbgenerated("NOW() + INTERVAL '90 days'")) @map("expires_at")
  createdAt         DateTime @default(now()) @map("created_at")

  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User                       @relation("ContributorCodes", fields: [createdByUserId], references: [id])
  redemptions    ContributorCodeRedemption[]
  parentCode     ContributorCode?           @relation("CodeHierarchy", fields: [parentCodeId], references: [id])
  childCodes     ContributorCode[]          @relation("CodeHierarchy")
  redeemedBy     User?                      @relation("RedeemedCodes", fields: [redeemedByUserId], references: [id])
  groundsCreated Ground[]                   @relation("GroundAccessCode")

  @@index([organizationId])
  @@map("contributor_codes")
}

model ContributorCodeRedemption {
  id               String   @id @default(uuid())
  codeId           String   @map("code_id")
  groundId         String   @map("ground_id")
  redeemedAt       DateTime @default(now()) @map("redeemed_at")
  redeemedByUserId String?  @map("redeemed_by_user_id")
  freeReason       String?  @map("free_reason")

  code       ContributorCode @relation(fields: [codeId], references: [id])
  ground     Ground          @relation(fields: [groundId], references: [id], onDelete: Cascade)
  redeemedBy User?           @relation("CodeRedemptions", fields: [redeemedByUserId], references: [id])

  @@map("contributor_code_redemptions")
}

model GroundDocument {
  id            String   @id @default(uuid())
  groundId      String   @map("ground_id")
  participantId String?  @map("participant_id")
  fileName      String   @map("file_name")
  mimeType      String   @map("mime_type")
  content       String   @db.Text
  assessment    Json?    // { suggests: string[], willDo: string[] } - Gemini's read of the doc, correctable

  createdAt DateTime @default(now()) @map("created_at")

  ground      Ground             @relation(fields: [groundId], references: [id], onDelete: Cascade)
  participant GroundParticipant? @relation(fields: [participantId], references: [id], onDelete: SetNull)

  @@index([groundId, participantId])
  @@map("ground_documents")
}

// Lead-supplied context: a private typed note the initiator adds about a specific
// participant (participantId set) or about the ground (participantId null). It
// DIRECTS and WEIGHTS synthesis - never becomes a stated claim, and is never shown
// to the person it is about. Deliberately its OWN store, NEVER a RecordEntry: the
// corpus reads these separately into a labeled LEAD-SUPPLIED CONTEXT section so the
// AI can never attribute the lead's framing to the party's own words.
model LeadContextNote {
  id            String   @id @default(uuid())
  groundId      String   @map("ground_id")
  participantId String?  @map("participant_id") // null = about the ground; set = about that person
  authorUserId  String   @map("author_user_id") // the initiator who wrote it
  text          String   @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  ground      Ground             @relation(fields: [groundId], references: [id], onDelete: Cascade)
  participant GroundParticipant? @relation(fields: [participantId], references: [id], onDelete: SetNull)

  @@index([groundId])
  @@map("lead_context_notes")
}

// ---------------------------------------------------------------------------
// Compliance — disclaimer acknowledgement gate before first session.
// ---------------------------------------------------------------------------

model DisclaimerAcknowledgement {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  groundId    String   @map("ground_id")
  textVersion String   @map("text_version") // slug of the disclaimer text version shown
  acknowledgedAt DateTime @default(now()) @map("acknowledged_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  ground Ground @relation(fields: [groundId], references: [id], onDelete: Cascade)

  @@unique([userId, groundId])
  @@index([groundId])
  @@map("disclaimer_acknowledgements")
}

// ---------------------------------------------------------------------------
// Report activation — mutual reveal gate. Both parties must activate before
// the report is released. Prevents one-sided reads.
// ---------------------------------------------------------------------------

enum ReportActivationStatus {
  PENDING   // party has not yet activated
  ACTIVATED // party pressed "release report"
}

model ReportActivation {
  id            String                 @id @default(uuid())
  groundId      String                 @map("ground_id")
  participantId String                 @map("participant_id")
  status        ReportActivationStatus @default(PENDING)
  activatedAt   DateTime?              @map("activated_at")
  createdAt     DateTime               @default(now()) @map("created_at")

  ground      Ground            @relation(fields: [groundId], references: [id], onDelete: Cascade)
  participant GroundParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([groundId, participantId])
  @@index([groundId])
  @@map("report_activations")
}

// ---------------------------------------------------------------------------
// Usage events — append-only ops log. Never updated, never deleted.
// Drives the ops dashboard and billing audit trail.
// ---------------------------------------------------------------------------

enum UsageEventType {
  GROUND_CREATED
  CHECK_IN_STARTED
  CHECK_IN_COMPLETED
  REPORT_REQUESTED       // party triggers mutual reveal
  REPORT_RELEASED        // both activated; releasedAt stamped on Report
  BILLING_ACTIVATED
  PARTICIPANT_INVITED
  PARTICIPANT_ACCEPTED
  ORG_CREATED
  SUBSCRIPTION_STARTED
  SUBSCRIPTION_CANCELLED
}

model UsageEvent {
  id             String         @id @default(uuid())
  organizationId String?        @map("organization_id")
  groundId       String?        @map("ground_id")
  participantId  String?        @map("participant_id")
  userId         String?        @map("user_id")
  type           UsageEventType
  meta           Json?          // arbitrary key-value for event-specific detail
  createdAt      DateTime       @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([groundId])
  @@index([type, createdAt])
  @@map("usage_events")
}

// ---------------------------------------------------------------------------
// Pattern thresholds — tunable per code without a deploy.
// One row per pattern code. Missing rows fall back to hardcoded defaults.
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Platform settings — generic singleton key/value store for admin-toggleable
// platform-wide flags (e.g. WhatsApp on/off). Not org-scoped: there is one
// Groundwork WhatsApp number serving every org, so this is a single row per
// key, not one per organization.
// ---------------------------------------------------------------------------

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") // userId of last editor

  @@map("platform_settings")
}

model FeedbackSubmission {
  id        String   @id @default(uuid())
  tab       String
  pill      String
  text      String?
  status    String   @default("new")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tab, createdAt])
  @@map("feedback_submissions")
}

model PatternConfig {
  id                   String   @id @default(uuid())
  code                 String   @unique // e.g. "D4", "B2", "F1"
  consecutivePeriods   Int      @default(3) @map("consecutive_periods") // three-period gate
  outputScoreMax       Float?   @map("output_score_max")   // detector fires when outputScore < this
  outputScoreMin       Float?   @map("output_score_min")   // detector fires when outputScore > this
  thinkingScoreMax     Float?   @map("thinking_score_max")
  thinkingScoreMin     Float?   @map("thinking_score_min") // detector fires when thinkingScore > this
  meetingScoreMax      Float?   @map("meeting_score_max")
  meetingScoreMin      Float?   @map("meeting_score_min")
  specificityScoreMax  Float?   @map("specificity_score_max")
  keywordCountMin      Int?     @map("keyword_count_min")  // for keyword-based detectors
  enabled              Boolean  @default(true)
  updatedAt            DateTime @updatedAt @map("updated_at")
  updatedBy            String?  @map("updated_by") // userId of last editor

  @@map("pattern_configs")
}
