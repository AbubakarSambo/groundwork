# --- App ---
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/groundwork?schema=public"

# --- JWT ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- Anthropic (conversation engine, report synthesis, pattern detection) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=2048

# --- Stripe (USD billing) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CARE_FEE_PRICE_ID=price_...   # $20/mo recurring care fee
STRIPE_CARE_FEE_CENTS=2000
STRIPE_SCENARIO_FEE_CENTS=5000       # $50/person/month
STRIPE_CALLBACK_URL=http://localhost:5173/billing/callback

# --- Resend (transactional email) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Groundwork <noreply@myground.work>"

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
